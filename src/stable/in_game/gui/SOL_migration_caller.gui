# SOL built-in after-lobby detection widgets.
# Mirrors CMF's cmf_after_lobby_caller.gui mechanism.
# Both widgets are registered as scripted widgets (auto-instantiated globally).
# Logic is gated inside the scripted GUIs: no-op when CMF is present (cmf_active set).

# Widget 1: fires on widget creation — Country.IsValid becomes true after lobby/country-select.
# Detects new game vs save load and stamps version for new games.
widget = {
	name = "sol_after_lobby_caller"
	size = { 0 0 }
	datacontext = "[GetPlayer]"
	visible = "[Country.IsValid]"

	state = {
		name = sol_after_lobby_caller
		trigger_on_create = yes
		on_start = "[GetScriptedGui('sol_after_lobby_caller').Execute(GuiScope.End)]"
	}
}

# Widget 2: fires on _show transition — becomes visible once NOT in lobby.
# Fires migration event for old save loads.
widget = {
	name = "sol_load_after_lobby_caller"
	size = { 0 0 }
	datacontext = "[GetPlayer]"
	visible = "[And(Country.IsValid, Not(IsLobbyOpen))]"

	state = {
		name = _show
		on_start = "[GetScriptedGui('sol_load_after_lobby_caller').Execute(GuiScope.End)]"
	}
}
