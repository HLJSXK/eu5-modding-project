
# ============================================================
# SOL Substitute Goods Scarcity Tooltips
# ============================================================
# One ContextualTooltipType template per substitute group.
# Replaces the simple tooltip = "SOL_ICON_*_SCARCE_TT" on the
# population-tab icons in location_window.gui.
#
# Each template shows:
#   - Group title + icon
#   - Short description
#   - Per-good table: icon | name | SCARCE/OK | demand impact
#
# Demand impact column:
#   - SCARCE good:      #R -60%#!  (universal multiply = 0.4)
#   - OK good w/ boost: #G +X%#!   (dynamic; via sol_demand_boost_<good>)
#   - OK good, no boost: (blank)
#
# Script values used: SOL_substitute_good_indicators.txt
# Localization keys:  SOL_substitute_goods_l_english.yml
# ============================================================

# Shorthand macros for the per-good row visibility expressions.
# SCARCE:   GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_X_scarce'), '(CFixedPoint)0')
# BOOST>0:  GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_X'), '(CFixedPoint)0')
# (Inlined directly to avoid needing template support in Jomini)

# ──────────────────────────────────────────────────────────────
#  Helper template — one goods row
#  Not used directly; pattern is replicated per row below
#  because good name and variable names must be hardcoded.
# ──────────────────────────────────────────────────────────────


# ============================================================
#  GROUP: Alcohol  (wine, liquor, beer)
# ============================================================
template SOL_alcohol_scarce_tooltip {
    ContextualTooltipType = {
        blockoverride "title_icon" {
            icon = { using = tooltip_title_icon_size
                     texture = "gfx/interface/icons/trade_goods/icon_goods_wine.dds" }
        }
        blockoverride "title_text" { text = "SOL_TT_ALCOHOL_TITLE" }
        blockoverride "tooltip_content" {
            vbox = {
                layoutpolicy_horizontal = expanding
                TooltipTextBlock = {
                    blockoverride "text" { text = "SOL_TT_ALCOHOL_DESC" }
                }
                vbox = {
                    layoutpolicy_horizontal = expanding
                    margin = { 10 4 }
                    spacing = 2
                    # Header
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_LIST_HEADER" }
                        text_single = { min_width = 55 align = hcenter text = "SOL_TT_STATUS_HEADER" }
                        text_single = { min_width = 50 align = hcenter text = "SOL_TT_DEMAND_HEADER" }
                    }
                    # Row: wine
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        spacing = 4
                        icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_wine.dds" }
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_WINE" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_wine_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_STATUS_SCARCE" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_wine_scarce'), '(CFixedPoint)0'))]"
                            text = "SOL_TT_STATUS_OK" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_wine_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_DEMAND_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[And(Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_wine_scarce'), '(CFixedPoint)0')), GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_wine'), '(CFixedPoint)0'))]"
                            raw_text = "#G +[Location.MakeScope.ScriptValue('sol_demand_boost_wine')|0]%#!" }
                    }
                    # Row: liquor
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        spacing = 4
                        icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_liquor.dds" }
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_LIQUOR" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_liquor_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_STATUS_SCARCE" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_liquor_scarce'), '(CFixedPoint)0'))]"
                            text = "SOL_TT_STATUS_OK" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_liquor_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_DEMAND_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[And(Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_liquor_scarce'), '(CFixedPoint)0')), GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_liquor'), '(CFixedPoint)0'))]"
                            raw_text = "#G +[Location.MakeScope.ScriptValue('sol_demand_boost_liquor')|0]%#!" }
                    }
                    # Row: beer
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        spacing = 4
                        icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_beer.dds" }
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_BEER" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_beer_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_STATUS_SCARCE" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_beer_scarce'), '(CFixedPoint)0'))]"
                            text = "SOL_TT_STATUS_OK" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_beer_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_DEMAND_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[And(Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_beer_scarce'), '(CFixedPoint)0')), GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_beer'), '(CFixedPoint)0'))]"
                            raw_text = "#G +[Location.MakeScope.ScriptValue('sol_demand_boost_beer')|0]%#!" }
                    }
                }
            }
        }
    }
}


