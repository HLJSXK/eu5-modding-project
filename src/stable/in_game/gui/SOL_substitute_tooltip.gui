                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_coal_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_DEMAND_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[And(Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_coal_scarce'), '(CFixedPoint)0')), GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_coal'), '(CFixedPoint)0'))]"
                            raw_text = "#G +[Location.MakeScope.ScriptValue('sol_demand_boost_coal')|0]%#!" }
                    }
                    # Row: salt
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        spacing = 4
                        icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_salt.dds" }
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_SALT" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_salt_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_STATUS_SCARCE" }
                        text_single = { min_width = 55 align = hcenter
                            visible = "[Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_salt_scarce'), '(CFixedPoint)0'))]"
                            text = "SOL_TT_STATUS_OK" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_salt_scarce'), '(CFixedPoint)0')]"
                            text = "SOL_TT_DEMAND_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            visible = "[And(Not(GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_salt_scarce'), '(CFixedPoint)0')), GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_demand_boost_salt'), '(CFixedPoint)0'))]"
                            raw_text = "#G +[Location.MakeScope.ScriptValue('sol_demand_boost_salt')|0]%#!" }
                    }
                    # Row: victuals (only shown when Prosper or Perish compatibility is active)
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        spacing = 4
                        visible = "[GreaterThan_CFixedPoint(Location.MakeScope.ScriptValue('sol_good_victuals_scarce'), '(CFixedPoint)0')]"
                        icon = { size = { 20 20 } texture = "gfx/interface/icons/trade_goods/icon_goods_victuals.dds" }
                        text_single = { layoutpolicy_horizontal = expanding text = "SOL_TT_GOODS_VICTUALS" }
                        text_single = { min_width = 55 align = hcenter
                            text = "SOL_TT_STATUS_SCARCE" }
                        text_single = { min_width = 50 align = hcenter
                            text = "SOL_TT_DEMAND_SCARCE" }
                    }
                }
            }
        }
    }
}
