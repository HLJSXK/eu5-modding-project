
template message_template {
	name = "basic_message_template"
	parentanchor = center
	allow_outside = yes
	
	# using = bg_window_message_t3

	vbox = {
		block "msg_size" {
			minimumsize = { 600 300 }
			maximumsize = { 600 300 }
		}
		set_parent_size_to_minimum = yes
		using = snd_UI_popup_show

		vbox = {
			using = layoutpolicy_expanding
			bottomtotop = yes

			vbox = {
				block "message_template_content_margin" { margin = {5 15} }
				spacing = 10
				using = layoutpolicy_expanding
				using = bg_age_event_inner
				using = bg_age_event_frame

				widget = {
					allow_outside = yes
	
					block "desc_spacing" {
						size = { 1 1 }
					}
				}

				block "message_template_content_custom" {
					vbox = {
						layoutpolicy_horizontal = expanding
						margin = { 30 0 }
						spacing = 5
	
						block "message_template_content" {
							scrollarea = {
								layoutpolicy_horizontal = expanding
								maximumsize = { -1 500 }
								
								scrollbarpolicy_horizontal = always_off
								autoresizescrollarea = yes
				
								scrollbar_vertical = {
									using = Scrollbar_Vertical
								}
				
								scrollwidget = {
									vbox = {
										visible = "[MessagePopup.HasDescription]"
	
										set_parent_dimension_to_minimum = height
										layoutpolicy_horizontal = expanding
										using = message_text_box_background
	
										text_multi = {
											layoutpolicy_horizontal = expanding
											size = {-1 60}
											autoresize = yes
											minimumsize = { 500 -1 }
											maximumsize = { 500 -1 }
											using = Font_Type_Standard
											fontsize = 17
											default_format = "#medium"
											align = center
											text = "[MessagePopup.GetDescription]"
											margin = { 10 20 }
										}
									}
								}
							}
	
							scrollarea = {
								layoutpolicy_horizontal = expanding
								maximumsize = { -1 200 }
								
								scrollbarpolicy_horizontal = always_off
								autoresizescrollarea = yes
				
								scrollbar_vertical = {
									using = Scrollbar_Vertical
								}
				
								scrollwidget = {
									TooltipBlockListContent = {
										visible = "[MessagePopup.HasEffect]"
	
										set_parent_dimension_to_minimum = height
										layoutpolicy_horizontal = expanding
										using = message_text_box_background
	
										ontextcontextchanged = "[SetBlockListFromTextContext(PdxGuiWidget.AccessSelf)]"
										textcontext = "[MessagePopup.GetEffect]"
										margin = { 10 10 }
									}
								}
							}
							vbox = {
								layoutpolicy_horizontal = expanding
								using = message_text_box_background		
								visible = "[MessagePopup.HasFlavor]"
			
								text_multi = {
									autoresize = yes
									using = Font_Type_Flavor
									maximumsize = { 500 -1 }
									minimumsize = { 500 -1 }
									text = "[MessagePopup.GetFlavor]"
									margin = { 10 20 }
								}
							}
						}
					}
	
					hbox = {
						margin = { 0 10 }
						spacing = 50
			
						block "message_template_buttons" {
			
							button_regular_diamond = {
								# DefaultButtonLockingProgress = {
								# 	datacontext = "[MessagePopup.GetLockableInfo]"
								# }
				
								enabled = "[MessagePopup.GetLockableInfo.IsUnlocked]"
								name = "decline_button"
								tooltip_enabled = no
								text = "[MessagePopup.GetDeclineText]"
								using = button_resize_to_fit_text
								using = snd_UI_close
				
								block "decline_title" {
									text = "CANCEL_BUTTON"
								}
				
								block "decline_visible" {
									visible = no
								}
				
								# block "decline_input_action" {
									onclick = "[MessagePopup.OnDecline]"
								# }
							}
				
							button_regular_diamond = {
								name = "goto_button"
								tooltip_enabled = no
								using = button_resize_to_fit_text
				
								block "goto_title" {
									text = "GOTO_GOTO"
								}
				
								block "goto_visible" {
									visible = "[MessagePopup.CanGoTo]"
								}
				
								onclick = "[MessagePopup.OnGoTo]"
							}
				
							button_regular_diamond = {
								# DefaultButtonLockingProgress = {
								# 	datacontext = "[MessagePopup.GetLockableInfo]"
								# }
				
								enabled = "[MessagePopup.GetLockableInfo.IsUnlocked]"
								name = "accept_button"
								tooltip_enabled = no
								text = "[MessagePopup.GetAgreeText]"
								using = button_resize_to_fit_text
								using = snd_UI_popup_confirm
				
								block "accept_title" {
									text = "OK_BUTTON"
								}
				
								# block "accept_input_action" {
									onclick = "[MessagePopup.OnAccept]"
									# input_action = "confirm"
									# use_global_input_instance = yes
								# }
							}
						}
					}
				}
	
			}

			hbox = {
				
				using = bg_age_event_title
				layoutpolicy_horizontal = expanding
	
				blockoverride "bg_event_title_texture" {
					texture = "gfx/interface/component_tiles/bg_big_round_corners_up.dds"
					texture_density = 2
					spriteType = corneredstretched
					spriteBorder = { 40 40 }
					margin = {3 0}
					margin_bottom = -2
				}
				
				widget = {
					layoutpolicy_vertical = expanding
					size = {5 -1}
					
					AgeEventDecorationTop = {
						size = {64 52}
						position = { -10 -2 }
						parentanchor = left|top
						widgetanchor = top
					}

					AgeEventDecorationTop2 = {
						parentanchor = left|bottom
						position = {-4 15}
						mirror = horizontal
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					margin = { 40 20 }
					spacing = 15
					
					block "message_decoration_left" {}
	
					block "message_title_content" {
						hbox = {
							
							vbox = {
									
								textbox = {
									using = text_multi_template
	
									name = "subtitle"
									
									autoresize = yes
									maximumsize = { 350 -1 }
									
									fontsize = 19
									default_format = "#subtle_name"
									align = center
									text = "[MessagePopup.GetSubtitle]"
								}
	
								textbox = {
									using = text_multi_template
	
									autoresize = yes
									maximumsize = { 350 -1 }
	
									default_format = "#yellow_titles"
									fontsize = 22
									align = center|nobaseline
									text = "[MessagePopup.GetTitle]"
								}
							}
						}
					}
	
					block "message_decoration_right" {}
				}

				widget = {
					layoutpolicy_vertical = expanding
					size = {5 -1}

					AgeEventDecorationTop = {
						size = {64 52}
						position = { -53 -2 }
						parentanchor = right|top
						widgetanchor = top
						mirror = horizontal
					}

					AgeEventDecorationTop2 = {
						parentanchor = right|bottom
						position = {4 15}
					}
				}
			}
		}
	}

	widget = {
		ignore_layout = yes
		allow_outside = yes
		parentanchor = top|right
		position = {-10 5}
		size = {55 55}
		
		# Avoiding using cancel input action in go-to button
		button_close_alt = {
			name = "dummy_button"
			tooltip_enabled = no
			parentanchor = left|top
			position = {25 20}

			size = { 22 22 }
			using = bg_circle

			input_action = "close_window"
			use_global_input_instance = yes
			onclick = "[MessagePopup.OnAccept]"
			# using = snd_UI_confirm
			using = bg_circle_piechart
		}

		button_menu_alt = {
			name = "message_settings"
			tooltipwidget = { LeftClickButtonTooltip = { blockoverride "onclick_text" { text = "MESSAGE_SETTINGS_POPUP" } } }
			parentanchor = left|top
			position = {25 20}
 
			blockoverride "close_inputaction" {}
			blockoverride "button_texture" {
				texture = "gfx/interface/buttons/flats/list_button.dds"
			}

			onclick = "[MessagePopup.OpenMessagePopup]"
			size = { 22 22 }
			using = bg_circle
			using = bg_circle_piechart
		}
	}
}

template peace_message_units_block {
	hbox = {
		overlappingitembox = {
			size = { 315 170 }
			spacing = 7
			block "peace_message_units_block_datamodel" { datamodel = "[CountryMessage.GetWarInfo.GetAttackerUnitStats]" }
			ignoreinvisible = yes

			item = {
				widget = {
					size = { 75 170 }
					vbox = {
						alwaystransparent = no
						filter_mouse = all
						margin = {3 3}
						margin_top = 8
						tagtooltip_enabled = yes
						tooltip = "WAR_UNIT_TYPE_STATS_TT"

						datacontext = "[FinishedWarUnitStats]"
						using = bg_paper_card
						using = bg_cabinet_card_frame

						blockoverride "unit_block_color" {
							modify_texture = {
								visible = "[Not(EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0'))]"
								using = color_bg_blue_texture
								blend_mode = multiply
							}

							modify_texture = {
								visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0')]"
								using = color_greyish_texture
								blend_mode = multiply
							}

							modify_texture = {
								visible = "[Not(EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0'))]"
								using = overlay_stone_texture
								blend_mode = overlay
								alpha = 0.8
							}

							modify_texture = {
								visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0')]"
								using = overlay_striped_texture
								blend_mode = overlay
								alpha = 0.1
							}
						}

						widget = {
							size = { 52 52 }
							icon = {
								size = { 70% 70% }
								parentanchor = center
								texture = "[GetSubUnitCategoryIcon(FinishedWarUnitStats.GetCategory)]"
							}
							using = bg_circle_piechart
						}

						expand = {}
						vbox = {
							layoutpolicy_horizontal = expanding

							widget = {
								size = { -1 26 }
								layoutpolicy_horizontal = expanding
								background = {
									texture = "gfx/interface/colors/dark_blue.dds"
									alpha = 0.4
								}
								hbox = {
									tooltipwidget = {
										SimpleContextualTooltipType = {
											blockoverride "title_icon" {
												icon = {
													using = tooltip_title_icon_size
													texture = "[GetSubUnitCategoryIcon(FinishedWarUnitStats.GetCategory)]"
												}
											}

											blockoverride "concept_link" {
												text = "[unit_category|e]"
											}

											lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_TOTAL_UNITS"

										}
									}
									text_single = {
										visible = "[Not(EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0'))]"
										text = "[FinishedWarUnitStats.GetVisualSize]"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_gray"
									}
									text_single = {
										visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetSize, '(CFixedPoint)0')]"
										raw_text = "0"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_gray"
									}
								}
							}

							widget = {
								size = { -1 26 }
								layoutpolicy_horizontal = expanding
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "[GetSubUnitCategoryIcon(FinishedWarUnitStats.GetCategory)]"
											}
										}

										blockoverride "concept_link" {
											text = "[unit_category|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_LOSSES"

									}
								}
								hbox = {
									text_single = {
										visible = "[Not(EqualTo_CFixedPoint(FinishedWarUnitStats.GetDestroyed, '(CFixedPoint)0'))]"
										raw_text = "-[FinishedWarUnitStats.GetDestroyed|-0]"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_red"
									}
									text_single = {
										visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetDestroyed, '(CFixedPoint)0')]"
										raw_text = "0"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_gray"
									}
								}
							}

							widget = {
								size = { -1 26 }
								layoutpolicy_horizontal = expanding
								background = {
									texture = "gfx/interface/colors/dark_blue.dds"
									alpha = 0.4
								}
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "[GetSubUnitCategoryIcon(FinishedWarUnitStats.GetCategory)]"
											}
										}
										blockoverride "concept_link" {
											text = "[unit_category|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_CAPTURED"

									}
								}
								hbox = {
									text_single = {
										visible = "[LessThan_CFixedPoint(FinishedWarUnitStats.GetImprisoned, '(CFixedPoint)0')]"
										raw_text = "[FinishedWarUnitStats.GetImprisoned|0]"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_red"
									}
									text_single = {
										visible = "[GreaterThan_CFixedPoint(FinishedWarUnitStats.GetImprisoned, '(CFixedPoint)0')]"
										raw_text = "+[FinishedWarUnitStats.GetImprisoned|+0]"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_green"
									}
									text_single = {
										visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetImprisoned, '(CFixedPoint)0')]"
										raw_text = "0"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_gray"
									}
								}
							}

							widget = {
								size = { -1 26 }
								layoutpolicy_horizontal = expanding
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "[GetSubUnitCategoryIcon(FinishedWarUnitStats.GetCategory)]"
											}
										}
										blockoverride "concept_link" {
											text = "[unit_category|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_REMAINING_UNITS"

									}
								}
								hbox = {
									text_single = {
										visible = "[Not(EqualTo_CFixedPoint(FinishedWarUnitStats.GetRemaining, '(CFixedPoint)0'))]"
										datacontext = "[FinishedWarUnitStats]"
										autoresize = yes
										text = "[FinishedWarUnitStats.GetRemaining]"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_white"
									}
									text_single = {
										visible = "[EqualTo_CFixedPoint(FinishedWarUnitStats.GetRemaining, '(CFixedPoint)0')]"
										autoresize = yes
										raw_text = "0"
										align = center|nobaseline
										alwaystransparent = yes
										default_format = "#color_gray"
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

template default_land_navy_icon {
	size = { 50 28 }
	
	using = bg_dual_list_item

	hbox = {
		parentanchor = center
		icon = {
			block "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/armies_end_of_battle.dds" }
			size = { 20 20 }
		}
	}
}

template peace_piechart_attacker_side_block {
	minimumsize = { 169 40 }
	using = bg_paper_card
	using = bg_cabinet_card_frame

	widget = {
		size = { 40 40 }
		piechart = {
			using = bg_circle
			parentanchor = vcenter|left
			size = { 40 40 }
			minimumsize = { 40 40 }
			using = piechart_angles

			pieslice_no_highlight = {
				texture = "gfx/interface/pie_charts/pie_chart_alpha_80_green.dds"
				block "attacker_side_green_value" {
					value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetAttackerTotalPopulation, CountryMessage.GetWarInfo.GetAttackerPopulationLosses))]"
				}
				color = { 1 1 1 1 }
			}

			pieslice_no_highlight = {
				texture = "gfx/interface/pie_charts/pie_chart_alpha_80_red.dds"
				block "attacker_side_red_value" {
					value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetAttackerPopulationLosses)]"
				}
				color = { 1 1 1 1 }
			}

			icon = {
				size = { 60% 60% }
				parentanchor = center
				block "texture_attacker_piechart" { texture = "gfx/interface/icons/disasters/_default.dds" }
			}

			using = bg_circle_piechart
		}
	}

	expand = {}
	vbox = {
		margin = { 8 0 }
		text_single = {
			fontsize = 12
			block "attacker_side_title" {
				text = "TOTAL_POPULATION_CASUALTIES"
			}
			default_format = "#color_white"
		}

		text_single = {
			fontsize = 12
			block "attacker_side_value" {
				raw_text = "-[CountryMessage.GetWarInfo.GetAttackerPopulationLossesDisplay]@population!"
			}
			default_format = "#color_red"
		}
	}
	expand = {}
}

template peace_piechart_defender_side_block {
	minimumsize = { 169 40 }
	using = bg_paper_card
	using = bg_cabinet_card_frame
	expand = {}

	vbox = {
		margin = { 8 0 }
		text_single = {
			fontsize = 12
			block "defender_side_title" {
				text = "TOTAL_POPULATION_CASUALTIES"
			}
			default_format = "#color_white"
		}

		text_single = {
			fontsize = 12
			block "defender_side_value" {
				raw_text = "-[CountryMessage.GetWarInfo.GetDefenderPopulationLossesDisplay]@population!"
			}
			default_format = "#color_red"
		}
	}
	expand = {}

	widget = {
		size = { 40 40 }
		piechart = {
			using = bg_circle
			parentanchor = vcenter|left
			size = { 40 40 }
			minimumsize = { 40 40 }
			using = piechart_angles

			pieslice_no_highlight = {
				texture = "gfx/interface/pie_charts/pie_chart_alpha_80_green.dds"
				block "defender_side_green_value" {
					value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetDefenderTotalPopulation, CountryMessage.GetWarInfo.GetDefenderPopulationLosses))]"
				}
				color = { 1 1 1 1 }
			}

			pieslice_no_highlight = {
				texture = "gfx/interface/pie_charts/pie_chart_alpha_80_red.dds"
				block "defender_side_red_value" {
					value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetDefenderPopulationLosses)]"
				}
				color = { 1 1 1 1 }
			}

			icon = {
				size = { 60% 60% }
				parentanchor = center
				block "texture_defender_piechart" { texture = "gfx/interface/icons/disasters/_default.dds" }
			}

			using = bg_circle_piechart
		}
	}
}

