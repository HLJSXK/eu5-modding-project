window = {
	name = "basic_message_popup"
	using = message_template
}

window = {
	using = message_template
	name = "character_message_popup"

	blockoverride "snd_popup_type" { soundeffect = "UI_popup_character_message" }

	blockoverride "message_decoration_left" {
		character_frame_small = {
			blockoverride "character_frame_size" {
				size = { 78 92 }
			}
			blockoverride "character_frame_texture" {
				texture = "gfx/interface/component_decoration/character_frames/character_non_stretchable_frame_2.dds"
			}
			blockoverride "portrait_datacontext" {
				datacontext = "[CharMessage.GetCharacter]"
			}
			blockoverride "character_portrait_visible" {
				visible = no
			}
			blockoverride "character_portrait_ani_visible" {
				visible = yes
			}
		}
	}

	blockoverride "message_decoration_right" {
		country_flag_big = {
			datacontext = "[CharMessage.GetCharacter.GetCourtCountry]"
		}
	}

	blockoverride "goto_title" {
		text = "SHOW_CHARACTER"
	}
}

window = {
	using = message_template
	name = "location_message_popup"

	blockoverride "snd_popup_type" { soundeffect = "UI_popup_location_message" }
}

window = {
	using = message_template
	name = "country_message_popup"

	blockoverride "snd_popup_type" { soundeffect = "UI_popup_country_message" }

	blockoverride "message_decoration_left" {
		country_flag_big = {
			datacontext = "[CountryMessage.GetFirstCountry]"
		}
	}

	blockoverride "message_decoration_right" {
		country_flag_big = {
			visible = "[Not(CountryMessage.IsEstatesLoan)]"
			datacontext = "[CountryMessage.GetSecondCountry]"
		}

		icon = {
			visible = "[CountryMessage.IsEstatesLoan]"
			texture = "gfx/interface/icons/location_icons/estates.dds"
			size = { 60 60 }

			modify_texture = {
				using = overlay_stone_texture
				blend_mode = overlay
				alpha = 1
			}

			modify_texture = {
				using = overlay_window_texture
				blend_mode = overlay
				alpha = 1
			}

			glow = {
				name = "drop_shadow"
				glow_radius = 3
				color = {0.0 0.0 0.0 1.0}
				alpha = 0.3
			}
		}
	}

	blockoverride "goto_title" {
		text = "GOTO_COUNTRY"
	}
}

window = {
	using = message_template
	name = "research_message_popup"

	blockoverride "snd_popup_type" { soundeffect = "UI_popup_country_message" }

	blockoverride "message_decoration_left" {
		icon = {
			texture = "[GetAdvanceIcon(ResearchMessage.GetAdvancePointer.GetDefinition)]"
			size = { 60 60 }

			modify_texture = {
				using = overlay_stone_texture
				blend_mode = overlay
				alpha = 1
			}

			modify_texture = {
				using = overlay_window_texture
				blend_mode = overlay
				alpha = 1
			}

			glow = {
				name = "drop_shadow"
				glow_radius = 3
				color = {0.0 0.0 0.0 1.0}
				alpha = 0.3
			}
		}
	}

	blockoverride "message_decoration_right" {
		icon = {
			texture = "[GetAdvanceIcon(ResearchMessage.GetAdvancePointer.GetDefinition)]"
			size = { 60 60 }

			modify_texture = {
				using = overlay_stone_texture
				blend_mode = overlay
				alpha = 1
			}

			modify_texture = {
				using = overlay_window_texture
				blend_mode = overlay
				alpha = 1
			}

			glow = {
				name = "drop_shadow"
				glow_radius = 3
				color = {0.0 0.0 0.0 1.0}
				alpha = 0.3
			}
		}
	}

	blockoverride "goto_visible" {
		visible = yes
	}

	blockoverride "goto_title" {
		text = "OPEN_ADVANCES_TREE"
	}
}

window = {
	using = message_template
	name = "peace_message_popup"

	blockoverride "snd_popup_type" { soundeffect = "UI_popup_country_message" }
	blockoverride "msg_size" {
		minimumsize = { 810 550 }
		maximumsize = { 810 550 }
	}

	blockoverride "message_template_content_margin" { margin = {5 -5} }

	blockoverride "message_template_content_custom" {
		vbox = {
			using = bg_declare_war_header_sides
			blockoverride "bg_declare_war_header_sides_margin" { 
				margin = { 0 -30 }
			}
			blockoverride "header_color" {
				#Player won
				modify_texture = {
					visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
					using = color_mid_green_texture
					blend_mode = multiply
				}
				modify_texture = {
					visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
					using = color_blue_texture
					blend_mode = overlay
				}	
				modify_texture = {
					visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
					using = color_bone_texture
					blend_mode = overlay
				}	
				modify_texture = {
					visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
					using = overlay_cloth_texture
					blend_mode = overlay
					alpha = 0.2
				}
				
				#Player lost
				modify_texture = {
					visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
					using = color_light_red_texture
					blend_mode = multiply
				}
				modify_texture = {
					visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
					using = color_whiteish_texture
					blend_mode = overlay
				}
				modify_texture = {
					visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
					using = color_whiteish_texture
					blend_mode = overlay
					alpha = 0.5
				}
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				margin = {0 5}
				margin_bottom = 12
				using = bg_declare_war_header_flag_01
				
				blockoverride "header_color" {
					modify_texture = {
						using = overlay_cloth_texture
						blend_mode = overlay
						alpha = 0.2
					}
					#Player won
					modify_texture = {
						visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
						using = color_mid_green_texture
						blend_mode = multiply
					}
					modify_texture = {
						visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
						using = color_blue_texture
						blend_mode = overlay
					}	
					modify_texture = {
						visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
						using = color_bone_texture
						blend_mode = overlay
					}

					#Player lost
					modify_texture = {
						visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
						using = color_light_red_texture
						blend_mode = multiply
					}
					modify_texture = {
						visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
						using = color_whiteish_texture
						blend_mode = overlay
					}
					modify_texture = {
						visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
						using = color_whiteish_texture
						blend_mode = overlay
						alpha = 0.5
					}
				}

				text_single = {
					using = Font_Size_Medium
					align = center|nobaseline
					margin_bottom = 2
					text = "[SelectLocalization(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self), 'WAR_WON_NO_SCORE', 'WAR_LOST_NO_SCORE')]"
				}
			}

			hbox = {
				margin = { 18 0 }
				vbox = {
					using = layoutpolicy_expanding
					using = bg_cabinet_card_frame
					background = {
						texture = "gfx/interface/component_tiles/navigational_square_tile.dds"
						texture_density = 2
						margin = {-3 -3}
						modify_texture = {
							visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
							using = color_mid_green_texture
						}
						modify_texture = {
							visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
							using = color_dark_red_texture
						}
						modify_texture = {
							using = overlay_cloth_texture
							blend_mode = overlay
							alpha = 0.2
						}
					}
	
					scrollarea = {
						scrollbarpolicy_horizontal = always_off
						
						autoresizescrollarea = no
						size = { 78 482 }
	
						scrollbar_vertical = {
							using = Scrollbar_Vertical
						}
						scrollwidget = {
							vbox = {
								layoutpolicy_vertical = expanding
								vbox = {
									margin_right = 1
									datamodel = "[CountryMessage.GetWarInfo.GetAttackerList]"
									item = {
										vbox = {
											minimumsize = { 60 45 }
											country_flag_mid = {
												size = {60 40}
											}
										}
									}
								}
								expand = {}
							}
						}
					}
					margin = { 2 4 }
				}
	
				vbox = {
					using = layoutpolicy_expanding
					maximumsize = { 780 -1 }
					spacing = 2
					hbox = {
						margin = { 30 0 }
						spacing = 10
	
						# Attacker side casualties
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/disasters/_default.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_POP_LOSSES"
								}
							}
							using = peace_piechart_attacker_side_block
						}
	
						# Defender side casualties
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/disasters/_default.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_POP_LOSSES"
								}
							}
							using = peace_piechart_defender_side_block
						}
					}

					vbox = {
						layoutpolicy_horizontal = expanding
						margin = { 5 0 }
						spacing = 5
	
						scrollarea = {
							layoutpolicy_horizontal = expanding
							maximumsize = { -1 500 }
							
							scrollbarpolicy_horizontal = always_off
							autoresizescrollarea = yes
			
							scrollbar_vertical = {
								using = Scrollbar_Vertical
							}
			
							scrollwidget = {
								vbox = {
									visible = "[MessagePopup.HasDescription]"
			
									set_parent_dimension_to_minimum = height
									layoutpolicy_horizontal = expanding
									using = message_text_box_background
			
									text_multi = {
										layoutpolicy_horizontal = expanding
										size = {-1 60}
										autoresize = yes
										minimumsize = { 620 -1 }
										maximumsize = { 620 -1 }
										using = Font_Type_Standard
										fontsize = 17
										default_format = "#medium"
										align = center
										text = "[MessagePopup.GetDescription]"
										margin = { 10 20 }
									}
								}
							}
						}

						vbox = {
							layoutpolicy_horizontal = expanding
							using = message_text_box_background		
							visible = "[MessagePopup.HasFlavor]"
		
							text_multi = {
								autoresize = yes
								using = Font_Type_Flavor
								maximumsize = { 500 -1 }
								minimumsize = { 500 -1 }
								text = "[MessagePopup.GetFlavor]"
								margin = { 10 20 }
							}
						}
					}

					# Land unit stats
					hbox = {
						# Attacker land
						widget = {
							size = { 340 170 }
							using = peace_message_units_block
						}

						#Default land icon
						vbox = {
							layoutpolicy_vertical = expanding
							expand = {}
							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/armies_start_of_battle.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_TOTAL_UNITS_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/armies_start_of_battle.dds" }
							}

							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_LOSSES_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds" }
							}

							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/armies_captured.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_CAPTURED_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/armies_captured.dds" }
							}

							widget = {
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/armies_end_of_battle.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_REMAINING_UNITS_GENERIC"
									}
								}
								using = default_land_navy_icon
							}
						}

						# Defender land
						widget = {
							size = { 340 170 }
							using = peace_message_units_block
							blockoverride "peace_message_units_block_datamodel" { datamodel = "[CountryMessage.GetWarInfo.GetDefenderUnitStats]" }
						}
					}

					# Naval unit stats
					hbox = {
						# Attacker naval
						widget = {
							size = { 340 170 }
							using = peace_message_units_block
							blockoverride "peace_message_units_block_datamodel" { datamodel = "[CountryMessage.GetWarInfo.GetAttackerNavalUnitStats]" }
						}

						#Default navy icon
						vbox = {
							layoutpolicy_vertical = expanding
							expand = {}
							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/navy_start_of_battle.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_TOTAL_UNITS_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/navy_start_of_battle.dds" }
							}

							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_LOSSES_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds" }
							}

							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/navy_captured.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_CAPTURED_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/navy_captured.dds" }
							}

							widget = {
								using = default_land_navy_icon
								tooltipwidget = {
									SimpleContextualTooltipType = {
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/battle_summary/navy_end_of_battle.dds" 
											}
										}

										blockoverride "concept_link" {
											text = "[units|e]"
										}

										lowpriotextcontext = "WAR_UNIT_TYPE_STATS_TT_REMAINING_UNITS_GENERIC"
									}
								}
								blockoverride "texture_default_land_navy_icon" { texture = "gfx/interface/icons/battle_summary/navy_end_of_battle.dds" }
							}
						}

						# Defender naval
						widget = {
							size = { 340 170 }
							using = peace_message_units_block
							blockoverride "peace_message_units_block_datamodel" { datamodel = "[CountryMessage.GetWarInfo.GetDefenderNavalUnitStats]" }
						}
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						margin = { 10 0 }
						spacing = 5
						# Attacker side army/navy casualties
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_ARMY_LOSSES"
								}
							}
							using = peace_piechart_attacker_side_block
							blockoverride "texture_attacker_piechart" { texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds" }
							blockoverride "attacker_side_title" {
								text = "TOTAL_ARMY_CASUALTIES"
							}
							blockoverride "attacker_side_green_value" {
								value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetAttackerArmyTotalStrength, CountryMessage.GetWarInfo.GetAttackerArmyDestroyedStrength))]"
							}
							blockoverride "attacker_side_red_value" {
								value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetAttackerArmyDestroyedStrength)]"
							}
							blockoverride "attacker_side_value" {
								raw_text = "-[CountryMessage.GetWarInfo.GetAttackerArmyDestroyedDisplay]@army_strength!"
							}
						}
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_NAVY_LOSSES"
								}
							}
							using = peace_piechart_attacker_side_block
							blockoverride "texture_attacker_piechart" { texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds" }
							blockoverride "attacker_side_title" {
								text = "TOTAL_NAVY_CASUALTIES"
							}
							blockoverride "attacker_side_green_value" {
								value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetAttackerNavyTotalStrength, CountryMessage.GetWarInfo.GetAttackerNavyDestroyedStrength))]"
							}
							blockoverride "attacker_side_red_value" {
								value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetAttackerNavyDestroyedStrength)]"
							}
							blockoverride "attacker_side_value" {
								raw_text = "-[CountryMessage.GetWarInfo.GetAttackerNavyDestroyedDisplay]@navy_strength!"
							}
						}

						expand = {}

						# Defender side army/navy casualties
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_NAVY_LOSSES"
								}
							}
							using = peace_piechart_defender_side_block
							blockoverride "texture_defender_piechart" { texture = "gfx/interface/icons/battle_summary/navy_destroyed.dds" }
							blockoverride "defender_side_title" {
								text = "TOTAL_NAVY_CASUALTIES"
							}
							blockoverride "defender_side_green_value" {
								value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetDefenderNavyTotalStrength, CountryMessage.GetWarInfo.GetDefenderNavyDestroyedStrength))]"
							}
							blockoverride "defender_side_red_value" {
								value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetDefenderNavyDestroyedStrength)]"
							}
							blockoverride "defender_side_value" {
								raw_text = "-[CountryMessage.GetWarInfo.GetDefenderNavyDestroyedDisplay]@navy_strength!"
							}
						}
						hbox = {
							tooltipwidget = {
								SimpleContextualTooltipType = {
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds"
										}
									}
	
									blockoverride "concept_link" {
										text = "[war|e]"
									}
	
									lowpriotextcontext = "PEACE_COUNTRY_ARMY_LOSSES"
								}
							}
							using = peace_piechart_defender_side_block
							blockoverride "texture_defender_piechart" { texture = "gfx/interface/icons/battle_summary/armies_destroyed.dds" }
							blockoverride "defender_side_title" {
								text = "TOTAL_ARMY_CASUALTIES"
							}
							blockoverride "defender_side_green_value" {
								value = "[FixedPointToFloat(Subtract_CFixedPoint(CountryMessage.GetWarInfo.GetDefenderArmyTotalStrength, CountryMessage.GetWarInfo.GetDefenderArmyDestroyedStrength))]"
							}
							blockoverride "defender_side_red_value" {
								value = "[FixedPointToFloat(CountryMessage.GetWarInfo.GetDefenderArmyDestroyedStrength)]"
							}
							blockoverride "defender_side_value" {
								raw_text = "-[CountryMessage.GetWarInfo.GetDefenderArmyDestroyedDisplay]@army_strength!"
							}
						}
					}
				}
	
				vbox = {
					using = layoutpolicy_expanding
					using = bg_cabinet_card_frame
					background = {
						texture = "gfx/interface/component_tiles/navigational_square_tile.dds"
						texture_density = 2
						margin = {-3 -3}
						modify_texture = {
							visible = "[CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self)]"
							using = color_mid_green_texture
						}
						modify_texture = {
							visible = "[Not(CountryMessage.GetWarInfo.IsWinningCountry(GetPlayer.Self))]"
							using = color_dark_red_texture
						}
						modify_texture = {
							using = overlay_cloth_texture
							blend_mode = overlay
							alpha = 0.2
						}
					}
	
					scrollarea = {
						scrollbarpolicy_horizontal = always_off
						
						autoresizescrollarea = no
						size = { 78 482 }
	
						scrollbar_vertical = {
							using = Scrollbar_Vertical
						}
						scrollwidget = {
							vbox = {
								layoutpolicy_vertical = expanding
								vbox = {
									datamodel = "[CountryMessage.GetWarInfo.GetDefenderList]"
									item = {
										vbox = {
											minimumsize = { 60 45 }
											country_flag_mid = {
												size = {60 40}
											}
										}
									}
								}
								expand = {}
							}
						}
					}
					margin = { 2 4 }
				}
			}

			vbox = {
				margin_top = 10
				layoutpolicy_horizontal = expanding
				spacing = 5
				hbox = {
					layoutpolicy_horizontal = expanding
					maximumsize = { 870 -1 }
					margin = { 0 5 }
					background = {
						texture = "gfx/interface/buttons/button_banner_02.dds"
						texture_density = 2
						alpha = 1
						spriteType = corneredstretched
						spriteborder = { 40 0 }
						frame_grid = {4 1}
						frame = 1
						margin = { 13 3 }

						modify_texture = {
							using = overlay_cloth_texture
							blend_mode = overlay
							alpha = 0.1
						}
					}
					text_single = {
						text = "game_concept_peace_treaty"
						default_format = "#T"
					}
				}
				
				scrollarea = {
					layoutpolicy_horizontal = expanding
					minimumsize = { 860 100 }
					maximumsize = { 860 200 }
					
					scrollbarpolicy_horizontal = always_off
					autoresizescrollarea = yes
	
					scrollbar_vertical = {
						using = Scrollbar_Vertical
					}
	
					scrollwidget = {
						TooltipBlockListContent = {
							visible = "[MessagePopup.HasEffect]"

							set_parent_dimension_to_minimum = height
							layoutpolicy_horizontal = expanding
							using = message_text_box_background

							ontextcontextchanged = "[SetBlockListFromTextContext(PdxGuiWidget.AccessSelf)]"
							textcontext = "[MessagePopup.GetEffect]"
						}
					}
				}
			}

			#GoTo and OK buttons
			hbox = {
				margin = { 0 10 }
				spacing = 50
				
				button_regular_diamond = {
					enabled = "[MessagePopup.GetLockableInfo.IsUnlocked]"
					name = "decline_button"
					tooltip_enabled = no
					text = "[MessagePopup.GetDeclineText]"
					using = button_resize_to_fit_text
					using = snd_UI_close
	
					visible = no
					onclick = "[MessagePopup.OnDecline]"
				}
	
				button_regular_diamond = {
					name = "goto_button"
					tooltip_enabled = no
					using = button_resize_to_fit_text
	
					text = "GOTO_GOTO"
					visible = "[MessagePopup.CanGoTo]"
	
					onclick = "[MessagePopup.OnGoTo]"
				}
	
				button_regular_diamond = {
					enabled = "[MessagePopup.GetLockableInfo.IsUnlocked]"
					name = "accept_button"
					tooltip_enabled = no
					text = "[MessagePopup.GetAgreeText]"
					using = button_resize_to_fit_text
					using = snd_UI_popup_confirm
	
					block "accept_title" {
						text = "OK_BUTTON"
					}
	
					onclick = "[MessagePopup.OnAccept]"
				}
			}
		}
	}

	blockoverride "message_decoration_left" {
		country_flag_big = {
			datacontext = "[CountryMessage.GetFirstCountry]"
		}
	}

	blockoverride "message_decoration_right" {
		country_flag_big = {
			visible = "[Not(CountryMessage.IsEstatesLoan)]"
			datacontext = "[CountryMessage.GetSecondCountry]"
		}

		icon = {
			visible = "[CountryMessage.IsEstatesLoan]"
			texture = "gfx/interface/icons/location_icons/estates.dds"
			size = { 60 60 }

			modify_texture = {
				using = overlay_stone_texture
				blend_mode = overlay
				alpha = 1
			}

			modify_texture = {
				using = overlay_window_texture
				blend_mode = overlay
				alpha = 1
			}

			glow = {
				name = "drop_shadow"
				glow_radius = 3
				color = {0.0 0.0 0.0 1.0}
				alpha = 0.3
			}
		}
	}

	blockoverride "goto_title" {
		text = "GOTO_COUNTRY"
	}
}

