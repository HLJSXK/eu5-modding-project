
types AlertSettingsTypes
{
	type AlertEntryItem = hbox {
		layoutpolicy_horizontal = expanding
		widget = {
			visible = "[Not(AlertEntry.IsActive)]"
			layoutpolicy_horizontal = expanding
			size = { -1 30 }

			button = {
				size = { 100% 100% }
				using = automatic_priority_alert_horizontal
				tooltip_enabled = no
				
				blockoverride "alert_button_setup" {
					enabled = "[AlertEntry.IsActive]"
					tooltip_enabled = no
				}
			}

			button = {
				size = { 100% 100% }

				using = automatic_priority_alert_horizontal
				alpha = 0.5

				action_tooltip = {
					click_type = right
					title = "ALERT_UNDISCARD"
					on_action = "[AlertEntry.SetUnmuted]"
				}

				tooltipwidget = { BasicFunctionalTooltip = {} }
			}

			hbox = {
				layoutpolicy_horizontal = expanding
				margin_left = 15
				margin_right = 5
				spacing = 10

				icon = {
					size = { 20 20 }
					enabled = "[AlertEntry.IsActive]"
					texture = "[AlertEntry.GetDescription.GetIcon]"
				}

				text_single = {
					layoutpolicy_horizontal = expanding
					align = nobaseline
					fontsize_min = 10
					autoresize = no
					multiline = yes
					text = "[AlertEntry.GetDescription.GetTitle]"
				}

				expand = {}
			}
		}

		widget = {
			visible = "[AlertEntry.IsActive]"
			layoutpolicy_horizontal = expanding
			size = { -1 30 }

			button = {
				size = { 100% 100% }
				using = automatic_priority_alert_horizontal

				action_tooltip = {
					click_type = left
					click_mode = single
					visible = "[AlertEntry.GetAlertAction.IsVisible]"
					enabled = "[AlertEntry.GetAlertAction.IsEnabled]"
					title = "[AlertEntry.GetAlertAction.GetName]"
					cost = "[AlertEntry.GetAlertAction.GetCost]"
					description = "[AlertEntry.GetAlertAction.GetDescription]"
					conditions = "[AlertEntry.GetAlertAction.GetConditions]"
					on_action_with_params = "[AlertEntry.GetAlertAction.PerformAction]"
				}

				action_tooltip = {
					click_type = right
					title = "ALERT_SHOW"
					clicksound = "UI_alert_discard"
					on_action = "[AlertEntry.Show]"
					on_action = "[AlertEntry.SetUnmuted]"
				}

				action_tooltip = {
					click_type = right
					click_modifier = shift
					visible = "[Not(AlertEntry.IsDiscarted)]"
					title = "ALERT_CTA_RIGHT_CLICK"
					on_action = "[AlertEntry.SetDiscarded]"
				}

				tagtooltip_enabled = yes
				tooltip = "[AlertEntry.GetDescription.GetTitleWithTooltip]"

				hbox = {
					layoutpolicy_horizontal = expanding
					margin_left = 10
					margin_right = 10
					spacing = 10

					icon = {
						size = { 20 20 }
						texture = "[AlertEntry.GetDescription.GetIcon]"
						enabled = "[AlertEntry.IsActive]"
					}

					text_single = {
						layoutpolicy_horizontal = expanding
						align = nobaseline
						fontsize_min = 10
						autoresize = no
						text = "[AlertEntry.GetDescription.GetTitle]"
					}

					widget = {
						size = { 20 20 }
					}
				}
			}

			hbox = {
				visible = "[Not(AlertEntry.IsDiscarted)]"
				layoutpolicy_horizontal = expanding
				margin_right = 15
				expand = {}
				button_notification = {
					size = { 20 20 }
					frame = "[Select_int32(AlertEntry.IsUnmuted, '(int32)1', '(int32)2')]"

					action_tooltip = {
						visible = "[AlertEntry.IsUnmuted]"
						title = "ALERT_MUTE"
						on_action = "[AlertEntry.SetMuted]"
					}

					action_tooltip = {
						visible = "[AlertEntry.IsMuted]"
						title = "ALERT_UNMUTE"
						on_action = "[AlertEntry.SetUnmuted]"
					}

					tooltipwidget = {
						ContextualTooltipType = {
							blockoverride "title_icon_texture" {
								using = button_notification_template
								using = tooltip_title_icon_size
								frame = "[Select_int32(AlertEntry.IsUnmuted, '(int32)1', '(int32)2')]"
							}

							blockoverride "title_text" {
								text = "[SelectLocalization(AlertEntry.IsMuted,'ALERT_MUTE_TITLE', 'ALERT_UNMUTE_TITLE')]"
							}
		
							blockoverride "tooltip_content" {
								TooltipTextBlock = {
									textcontext = "[SelectLocalization(AlertEntry.IsMuted,'ALERT_MUTED_TT', 'ALERT_UNMUTED_TT')]"
								}
							}
						}
					}
				}
			}
		}
	}

	type AlertSettingsCategoryTitle = widget {
		layoutpolicy_horizontal = expanding
		size = { -1 45 }

		icon = {
			size = { 100% 100% }
			ignore_layout = yes


			using = color_bronze_texture

			modify_texture = {
				texture = "gfx/interface/buttons/card_header_button_08.dds"
				frame_grid = {4 1}
				spriteType = Corneredstretched
				texture_density = 2
				spriteborder = { 40 40 }
				blend_mode = alphamultiply
			}

			background = {
				using = tile_background_squared_texture
				modify_texture = {
					using = color_bg_blue_texture
				}
				modify_texture = {
					using = overlay_cloth_texture
					blend_mode = overlay
					alpha = 0.1
				}
				modify_texture = {
					using = overlay_watercolor_texture
					blend_mode = multiply
					alpha = 0.2
				}
			}
		}

		button = {
			size = { 100% 100% }
			using = button_banner_02_texture
			block "title_button" {}
		}

		hbox = {
			margin = { 25 0 }
			margin_bottom = 6
			spacing = 10

			block "title_icon" {
				icon = {
					size = { 24 24 }
					block "title_icon_texture" {}
				}
			}

			text_single = {
				layoutpolicy_horizontal = expanding
				using = Font_Type_Headers
				default_format = "#T"
				align = nobaseline
				block "title_text" {}
			}

			block "title_right" {}
		}
	}

	type AlertSettingsCategory = vbox {
		layoutpolicy_horizontal = expanding
		spacing = 2

		AlertSettingsCategoryTitle = {}
		vbox = {
			layoutpolicy_horizontal = expanding
			margin = { 10 5 }
			spacing = 5

			using = bg_scroll_card_rendered

			block "category_datamodel" {}
			item = {
				block "category_item" {}
			}
		}
	}
	
	type AlertSettingsContent = vbox {
		layoutpolicy_horizontal = expanding
		spacing = 6

		AlertSettingsCategory = {
			visible = "[GreaterThan_int32(GetDataModelSize(AlertManager.GetHidden), '(int32)0')]"

			blockoverride "title_icon"
			{ 
				icon = {
					size = { 24 24 }
					using = button_notification_template
					
					# button_check_visibility = {
					# 	size = { 24 24 }
					# 	frame = "[Select_int32(AlertSettings.ShowInactive, '(int32)2', '(int32)1')]"

					# 	action_tooltip = {
					# 		title = "ALERT_SETTINGS_TOGGLE_VISIBILITY_UNACTIVE"
					# 		on_action = "[AlertSettings.ToggleInactive]"
					# 	}

					# 	tooltipwidget = { BasicFunctionalTooltip = {} }
					# }
				}
			}

			blockoverride "title_button" {
				action_tooltip = {
					title = "ALERT_SETTINGS_TOGGLE_VISIBILITY"
					on_action = "[AlertSettings.ToggleDiscarded]"
				}

				tooltipwidget = { BasicFunctionalTooltip = {} }
			}
			blockoverride "title_text" { text = "HIDDEN_ALERTS" }
			blockoverride "category_datamodel" { 
				visible = "[And(DataModelHasItems(AlertManager.GetHidden), AlertSettings.ShowDiscarded)]"
				datamodel = "[AlertManager.GetHidden]"
			}
			blockoverride "title_right" {
				text_single = {
					text = "[GetDataModelSize(AlertManager.GetHidden)]"
				}

				widget = {
					size = { 23 23 }
					widget = {
						size = { 100% 100% }
						visible = "[DataModelHasItems(AlertManager.GetHidden)]"

						background = {
							texture = "gfx/interface/buttons/checkbox_bg_round.dds"
							texture_density = 2
							modify_texture = {
								using = color_economy_texture
								alpha = 1
							}

							modify_texture = {
								using = overlay_cloth_texture
								blend_mode = overlay
								alpha = 0.2
							}
						}

						icon = {
							parentanchor = center
							visible = "[Not(AlertSettings.ShowDiscarded)]"
							size = { 16 16 }
							texture = "gfx/interface/buttons/flats/button_simple_right.dds"
							using = color_gold
							modify_texture = {
								using = overlay_window_texture
								blend_mode = overlay
								alpha = 1
							}

							glow = {
								glow_radius = 3
								color = {0.0 0.0 0.0 1.0}
								alpha = 0.3
							}
						}

						icon = {
							parentanchor = center
							visible = "[AlertSettings.ShowDiscarded]"
							size = { 16 16 }
							position = { 0 2 }
							texture = "gfx/interface/buttons/flats/button_simple_down.dds"
							using = color_gold
							modify_texture = {
								using = overlay_window_texture
								blend_mode = overlay
								alpha = 1
							}

							glow = {
								glow_radius = 3
								color = {0.0 0.0 0.0 1.0}
								alpha = 0.3
							}
						}
					}
				}
			}

			blockoverride "category_item" { 
				AlertEntryItem = {
					visible = "[Not(AlertEntry.IsDiscarted)]"
				} 
			}
		}

		AlertSettingsCategory = {
			visible = "[GreaterThan_int32(GetDataModelSize(AlertManager.GetDiscarded), '(int32)0')]"

			blockoverride "title_icon"
			{ 
				icon = {
					size = { 24 24 }
					using = button_visibility_template

					# button_check_visibility = {
					# 	size = { 24 24 }
					# 	frame = "[Select_int32(AlertSettings.ShowInactive, '(int32)2', '(int32)1')]"

					# 	action_tooltip = {
					# 		title = "ALERT_SETTINGS_TOGGLE_VISIBILITY_UNACTIVE"
					# 		on_action = "[AlertSettings.ToggleInactive]"
					# 	}

					# 	tooltipwidget = { BasicFunctionalTooltip = {} }
					# }
				}
			}
			blockoverride "title_button" {
				action_tooltip = {
					title = "ALERT_SETTINGS_TOGGLE_VISIBILITY"
					on_action = "[AlertSettings.ToggleHidden]"
				}

				tooltipwidget = { BasicFunctionalTooltip = {} }
			}
			blockoverride "title_text" { text = "DISCARDED_ALERTS" }
			blockoverride "category_datamodel" { 
				visible = "[And(DataModelHasItems(AlertManager.GetDiscarded), AlertSettings.ShowHidden)]"
				datamodel = "[AlertManager.GetDiscarded]"
			}
			blockoverride "title_right" {
				text_single = {
					text = "[GetDataModelSize(AlertManager.GetDiscarded)]"
				}

				widget = {
					size = { 23 23 }
					widget = {
						size = { 100% 100% }
						visible = "[DataModelHasItems(AlertManager.GetDiscarded)]"			

						background = {
							texture = "gfx/interface/buttons/checkbox_bg_round.dds"
							texture_density = 2
							modify_texture = {
								using = color_economy_texture
								alpha = 1
							}

							modify_texture = {
								using = overlay_cloth_texture
								blend_mode = overlay
								alpha = 0.2
							}
						}

						icon = {
							parentanchor = center
							visible = "[Not(AlertSettings.ShowHidden)]"
							size = { 16 16 }
							texture = "gfx/interface/buttons/flats/button_simple_right.dds"
							using = color_gold
							modify_texture = {
								using = overlay_window_texture
								blend_mode = overlay
								alpha = 1
							}

							glow = {
								glow_radius = 3
								color = {0.0 0.0 0.0 1.0}
								alpha = 0.3
							}
						}

						icon = {
							parentanchor = center
							visible = "[AlertSettings.ShowHidden]"
							size = { 16 16 }
							position = { 0 2 }
							texture = "gfx/interface/buttons/flats/button_simple_down.dds"
							using = color_gold
							modify_texture = {
								using = overlay_window_texture
								blend_mode = overlay
								alpha = 1
							}

							glow = {
								glow_radius = 3
								color = {0.0 0.0 0.0 1.0}
								alpha = 0.3
							}
						}
					}
				}
			}

			blockoverride "category_item" { 
				AlertEntryItem = {
					visible = "[And(AlertEntry.IsDiscarted, Or(AlertSettings.ShowInactive, AlertEntry.IsActive))]"
				} 
			}
		}
	}
}

window = {
	name = "alert_settings"
	parentanchor = top|right
	using = bg_small_menu

	datacontext = "[AlertSettings.GetManager]"

	position = { -455 125 }
	alpha = 1

	movable = no
	allow_outside = yes
	visible_at_creation = no

	using = Animation_Show_Hide_UI
	blockoverride "on_hide_ui" {
		position_y = -125
		alpha = 0
	}

	blockoverride "on_show_ui" {
		position_y = 125
		alpha = 1
	}

	vbox = {
		set_parent_size_to_minimum = yes

		vbox = {
			using = bg_message_dialog_title
			blockoverride "fold_margin" { alpha = 0 }
			blockoverride "fold_shadow_margin" { alpha = 0 }
			blockoverride "header_color" { using = color_dark_brown_texture }
			blockoverride "header_pattern" {
				texture = "gfx/interface/component_overlay/scrollwork_texture_01.dds"
				spriteborder = { 0 0 }
				alpha = 0
			}

			layoutpolicy_horizontal = expanding
			minimumsize = { -1 42 }
			margin = { 10 5 }
			spacing = 10

			text_multi = {
				using = layoutpolicy_expanding
				margin = { 10 0 }
				fontsize = 15
				align = center
				autoresize = yes
				using = Font_Size_Big

				default_format = "#header_titles"
				text = "ALERTS_SETTINGS_TITLE"
			}
		}

		scrollarea = {
			layoutpolicy_horizontal = expanding
			scrollbarpolicy_horizontal = always_off
			alwaystransparent = no
			autoresizescrollarea = yes

			maximumsize = { -1 900 }

			scrollbar_vertical = {
				using = Scrollbar_Vertical
			}

			scrollwidget = {
				vbox = {
					set_parent_size_to_minimum = yes
					minimumsize = { 380 -1 }
					margin = { 11 11 }
					AlertSettingsContent = {}
				}
			}
		}
	}

	button_close_alt = {
		parentanchor = right|top
		position = { -10 10 }
		blockoverride "close_onclick" {
			onclick = "[AlertSettings.OnClose]"
		}
	}
}
