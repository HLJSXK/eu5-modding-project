template MercenaryUnitType_Tooltip {
	ContextualTooltipType = {
		blockoverride "title_icon" {
			icon = {
				using = tooltip_title_icon_size
				texture = "[GetSubUnitCategoryIcon(AvailableMercenaryTypes.GetCategory)]"	#TODO avatars
				texture_density = 2
			}
		}
		blockoverride "title_text" {
			text = "[AvailableMercenaryTypes.GetCategory.GetNameWithNoTooltip]"
		}
		blockoverride "concept_link" {
			text = "[unit_category|e]"
		}
		
		blockoverride "tooltip_content" {
			TooltipListBase = { 
                # blockoverride "block_title" {
                #     text = "[AvailableMercenaryTypes.GetCategory.GetName]"
                # }
                TooltipListColumnContent = {
                    TooltipTableColumn = {
                        blockoverride "column_title" {}
                        blockoverride "column_title_text" { text = "MERCENARY_SUBUNITS_AMOUNT" }
                        blockoverride "column_title_right" { expand = {} }
                        blockoverride "field_left" {
                            icon = {
                                size = { 25 25 }
								texture = "[GetConceptTexture('mercenary')]"
                            }
                        }
                        blockoverride "field_text" {
                            raw_text = "[PossibleLeaderItem.GetSubUnitAmount(SubUnitCount.GetSubUnitDefinition)] / [SubUnitCount.GetCount]"
                            tooltipwidget = {
								SimpleContextualTooltipType = {
									textcontext = "[SubUnitCount.GetSubUnitDefinition.GetMercenaryUITooltip(SubUnitCount.GetCount)]"
									blockoverride "title_icon_texture" {
										texture = "[GetSubUnitCategoryIcon(SubUnitCount.GetSubUnitDefinition.GetCategory)]"
									}																	
								}
							}
                        }
                        blockoverride "field_right" { expand = {} }
                    }
                    TooltipTableColumn = {
                        blockoverride "column_title" {}
                        blockoverride "column_title_right" { expand = {} }
                        blockoverride "column_title_text" { text = "UNIT_CATEGORY_TYPE" }
                        blockoverride "field_text" {
                            text = "[SubUnitCount.GetSubUnitDefinition.GetName]"
                        }
                        blockoverride "field_right" { expand = {} }
                    }
                    TooltipTableColumn = {
						visible = "[AvailableMercenaryTypes.GetCategory.IsArmy]"
                        blockoverride "column_title" {}
                        blockoverride "column_title_left" { expand = {} }
                        blockoverride "column_title_text" { text = "ARMY_STRENGTH_LABEL" }
                        blockoverride "field_left" { expand = {} }
                        blockoverride "field_text" { raw_text = "[PossibleLeaderItem.GetVisualSubUnitStrength(SubUnitCount.GetSubUnitDefinition)]@army_strength!" }
                    }
                    blockoverride "column_datamodel"  {  datamodel = "[AvailableMercenaryTypes.GetSubunits]" }
                }
            }
		}
	}
}

