Types UnitTooltips
{
	type UnitTemplateCategoryInfo = TooltipManualTableField {
		blockoverride "field_content" {
			icon = {
				size = { 32 32 }
				texture = "[GetSubUnitCategoryIcon(SubUnitCategory.Self)]"
			}

			text_single = {

				text = "[SubUnitCategory.GetName]"
			}
			expand = {}

			hbox = {
				spacing = 4
				tagtooltip_enabled = yes
				tooltip = "[regulars|e]"

				text_single = {
					size = { 30 30 }
					autoresize = no
					align = right|nobaseline
					text = "[UnitTemplate.GetSubUnitCategoryAmount(SubUnitCategory.Self)]"
				}

				icon = {
					size = { 24 24 }
					visible = "[UnitTemplate.IsArmy]"
					texture = "gfx/interface/icons/unit_actions/regulars.dds"
				}

				icon = {
					size = { 24 24 }

					visible = "[Not(UnitTemplate.IsArmy)]"

					texture = "gfx/interface/icons/unit_category/regulars_navy.dds"
				}
			}

			text_single = {
				size = { 90 30 }
				autoresize = no
				align = right|nobaseline
				text = "[UnitTemplate.GetSubUnitCategoryStrength(SubUnitCategory.Self)]"
			}

			icon = {
				size = { 24 24 }
				visible = "[UnitTemplate.IsArmy]"
				texture = "gfx/interface/icons/unit_category/total_strength.dds"
			}

			icon = {
				size = { 24 24 }
				visible = "[Not(UnitTemplate.IsArmy)]"
				texture = "gfx/interface/icons/unit_view/formation_flat.dds"
			}
		}
	}
}