disaster_panel = {

	##################################### TOP HEADER #####################################

	# blockoverride "end_requirements_icon"{
	# 	icon = {
	# 		size = {32 32}
	# 		texture = "gfx/interface/icons/disasters/end_requirements.dds"
	# 		using = overlay_color_light_blue
	# 		tooltip = "[DisasterView.GetDisaster.GetType.GetEndConditions]"
	# 	}
	# }

	##################################### MAIN IMAGE #####################################

	blockoverride "main_image"{
		two_characters_header = {
			visible = "[DisasterView.IsDisaster('byzantine_succession_crisis')]"
			blockoverride "FirstCharacterContext" {
				datacontext = "[DisasterView.GetDisaster.GetOwner.GetGovernment.GetRulerOrRegent]"
			}
			blockoverride "SecondCharacterContext" {
				datacontext = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('GUI_pretender_rebel_character').GetCharacter]"
			}
			blockoverride "SecondCharacterRole" {
				country_character = {
					blockoverride "country_header_orientation" {
						righttoleft = yes
					}
					blockoverride "country_government_character_labels_align" {
						align = right|nobaseline
					}
					blockoverride "character_name_maximumsize" {
						maximumsize = { 200 -1 }
					}
					blockoverride "character_name_text"{
						text = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('GUI_pretender_rebel_character').GetCharacter.GetShortNameWithNoTooltip]"
					}

					blockoverride "character_title" {
						visible = "[Character.HasNickName]"
						text = "[Character.GetNickname]"
					}
				}
			}
			# blockoverride "history_button_anchor" { visible = no }
			blockoverride "first_character_portrait_anchor" { parentanchor = bottom|left }
			blockoverride "second_character_portrait_anchor" { parentanchor = bottom|right }
			blockoverride "character_religion_visibility" { visible = no }
			blockoverride "character_name_maximumsize" { maximumsize = { 270 -1 } }
			blockoverride "country_header_extra" {
				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 10 10 }
					spacing = 8
					expand = {}
				}
			}
		}
	}

	##################################### TAB NAME #####################################

	blockoverride "disaster_secondary_tab" {
		margin_top = 10
		spacing = 5
		disaster_card_expandable = {
			blockoverride "header_button_onclick" {
				onclick = "[LateralView.Vars.Toggle( 'requirements_toggled' )]"
			}
			blockoverride "header_text" {
				text = "END_REQUIREMENTS"
			}
			blockoverride "header_icon" {
				texture = "gfx/interface/icons/disasters/end_requirements_green.dds"
			}
			blockoverride "bottom_content" {
				TooltipRequirementsList = {
					textcontext = "[DisasterView.GetDisaster.GetType.GetEndConditions]"
				}
			}
			blockoverride "bottom_content_onclick" {
				visible = "[LateralView.Vars.Exists( 'requirements_toggled' )]"
			}
			blockoverride "icon_replace_visible_yes" {
				visible = "[LateralView.Vars.Exists( 'requirements_toggled' )]"
			}
			blockoverride "icon_replace_visible_not" {
				visible = "[Not(LateralView.Vars.Exists( 'requirements_toggled' ))]"
			}
		}
	}

	##################################### SUBHEADER #####################################

	

	##################################### MAIN CONTENT #####################################

	blockoverride "disaster_main_content_subheader" {}
	blockoverride "disaster_description" {}

	blockoverride "main_content" {
		card_list_button  = {
			layoutpolicy_horizontal = expanding
			size = { -1 60 }
			datacontext = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel]"

			action_tooltip = {
				on_action = "[ShowRebel(DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.Self)]"
				title = "OUTLINER_ITEM_SOCIETY_REBELS_TOOLTIP"
			}
			tooltipwidget = {
				using = Rebel_tooltip
			}

			hbox = {
				visible = "[DisasterView.GetDisaster.GetOwner.HasActiveRebels]"
				using = layoutpolicy_expanding
				margin = { 10 4 }
				spacing = 5
				datacontext = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel]"
				icon = {
					size = { 26 26 }
					texture = "gfx/interface/icons/rebels/fist.dds"
				}

				divider_flavor_03 = {size = { 8 -1 }}

				vbox = {
					text_single = {
						align = left|nobaseline
						text = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.GetNameWithNoTooltip]"
						default_format = "#yellow_titles"
					}
		
					text_single = {
						align = left|nobaseline
						using = Font_Size_Very_Small
						text = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.GetCategoryName]"
					}
				}
				divider_flavor_03 = {size = { 8 -1 }}
				vbox = {
					layoutpolicy_vertical = expanding
					using = bg_text_mask_container_brown
					margin = { 5 5 }
					expand = {}
					text_single = {
						layoutpolicy_horizontal = expanding
						size = { -1 30 }
						autoresize = no
						align = center|nobaseline
						text = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.GetProgress|2%]"
					}
		
					progressbar = {
						size = { 100 10 }
						using = morale_progressbar_bar
						value = "[Multiply_float(FixedPointToFloat(DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.GetProgress), '(float)100')]"
					}
					expand = {}
				}
				hbox = {
					layoutpolicy_vertical = expanding
					text_single = {
						using = bg_number_container_bckg
						size = { 60 45 }
						autoresize = no
						align = center|nobaseline
						text = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel.GetMonthlyChange|-=2%]"
						datacontext = "[DisasterView.GetDisaster.GetOwner.MakeScope.GetVariable('succession_crisis_pretender_variable').GetRebel]"
						tooltipwidget = { using = RebelMonthly_tooltip }
					}
				}	
			}
		}
	}
}
