lateralview = {
	name = "transfer_occupation_action_view"

	blockoverride "panel_header" {
		window_header_alt = {
			using = bg_main_inner_alt
			blockoverride "window_header_alt_color_texture"{
				using = color_default_brown_texture
			}

			blockoverride "header_text" {
				text = "[TransferOccupationActionView.GetHeaderTitle]"
			}
		}
	}

	blockoverride "panel_content" {
		vbox = {
			using = layoutpolicy_expanding
			using = bg_main_inner_alt
			using = window_main_tabs_margin_alt

			vbox = {
				using = layoutpolicy_expanding
				margin = { 10 0 }
				margin_bottom = 10
				spacing = 10

				filtered_sorted_list = {
					datacontext = "[TransferOccupationActionView.GetLocationsSortSearch]"

					blockoverride "scroll_list_is_empty" {
						visible = "[IsDataModelEmpty(TransferOccupationActionView.GetPossibleLocations)]"
					}

					blockoverride "scroll_list_is_empty_text" {
						text = "transfer_occupation_no_locations"
					}

					blockoverride "sort_buttons_filtered_list" {
						sort_by_key_button = {
							name = "name"
							using = layoutpolicy_expanding
						}
		
						sort_by_key_button = {
							name = "population"
							layoutpolicy_vertical = expanding
							size = { 105 -1 }
						}
					}

					blockoverride "scroll_list_content" {
						addcolumn = 100%
						addrow = 37

						datamodel = "[TransferOccupationActionView.GetPossibleLocations]"
						item = {
							card_list_button = {
								minimumsize = {510 37}
								maximumsize = {510 37}
								action_tooltip = {
									click_type = left
									click_mode = single
									title = "SELECT_LOCATION"
									on_action = "[TransferOccupationActionView.ToggleLocation(Location.Self)]"
								}
								action_tooltip = {
									click_type = right
									click_mode = confirm
									title = "SELECT_ALL_LOCATIONS"
									on_action = "[TransferOccupationActionView.ToggleAllLocations]"
								}

								using = layoutpolicy_expanding
								using = bg_card_header_01

								tooltipwidget = {
									ContextualTooltipType = {
										blockoverride "title_text" {
											text = "SELECT_LOCATION"
										}
										blockoverride "title_icon" {
											icon = {
												using = tooltip_title_icon_size
												texture = "gfx/interface/icons/map_subdivisons/location.dds"
											}
										}
										blockoverride "concept_link" {
											text = "[location|E]"
										}
										blockoverride "tooltip_content" {}
									}
								}

								hbox = {
									margin = {10 0}
									spacing = 5

									button_checkbox_alt = {
										size = { 20 20 }
										tooltip_enabled = no
										checked = "[TransferOccupationActionView.IsSelected(Location.Self)]"
										onclick = "[TransferOccupationActionView.ToggleLocation(Location.Self)]"
										allow_outside = yes
									}

									hbox = {
										layoutpolicy_horizontal = expanding
										spacing = 25

										hbox = {
											minimumsize = { 200 32 }
											margin = { 5 0 }
											spacing = 10

											icon = {
												size = { 18 18 }
												texture = "[Location.GetRankIcon]"
												datacontext = "[Location.GetRank]"
												tooltipwidget = { using = LocationRankTag_tooltip }
											}

											text_single = {
												size = { 180 20 }
												autoresize = no
												text = "[Location.GetNameWithNoTooltip]"
												default_format = "#yellow_titles"

												sort_by_highlight = {
													size = { 100% 100% }
													name = "name"
												}
											}
										}

										hbox = {
											size = { 100 32 }
											margin = { 5 0 }
											spacing = 10

											tooltipwidget = {
												using = population_location_tooltip
											}

											icon = {
												size = { 20 20 }
												layoutpolicy_vertical = fixed
												layoutpolicy_horizontal = fixed
												texture = "gfx/interface/icons/map_modes/population.dds"
												glow = {
													name = "drop_shadow"
													glow_radius = 3
													color = {0.0 0.0 0.0 1.0}
													alpha = 0.3
												}
											}

											text_single = {
												size = { 42 20 }
												autoresize = no
												text = "[Location.GetTotalPopulation]"
											}
										}
									}
								}
							}
						}
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					spacing = 10
					margin = { 5 10 }

					expand = {}

					vbox = {
						layoutpolicy_horizontal = expanding
						using = bg_number_container_bckg
						margin = { 5 10 }
						button_regular = {
							layoutpolicy_horizontal = expanding
							size = { -1 30 }
							
							text_single = {
								maximumsize = {120 -1}
								parentanchor = center
								text = "transfer_occupation"
							}
							icon = {
								position = { -5 0 }
								framesize = { 46 46 }
								size = { 23 23 }
								parentanchor = right|vcenter
					
								texture = "gfx/interface/icons/diplomatic_status/ai_accept_decline_icon.dds"
								frame = 2
							}
							
							tooltipwidget = {
								ContextualTooltipType = {
									blockoverride "title_text" {
										text = "transfer_occupation_select_title"
									}
									blockoverride "title_icon" {
										icon = {
											using = tooltip_title_icon_size
											texture = "gfx/interface/icons/resources/diplo_actions.dds"
										
										}
									}
									blockoverride "concept_link" {
										text = "[diplomatic_action|E]"
									}
									blockoverride "tooltip_content" {

										TooltipBlockList = {
											textcontext = "[TransferOccupationActionView.GetConfirmMessage]"
										}
									}
								}
							}
							action_tooltip = {
								click_type = left
								click_mode = confirm
								title = "transfer_occupation_select_title"
								description = "[TransferOccupationActionView.GetConfirmMessage]"
								enabled = "[TransferOccupationActionView.CanSend]"
								on_action = "[TransferOccupationActionView.OnSend]"
							}
						}
					}
				}
			}
		}
	}
}


