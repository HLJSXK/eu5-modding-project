template select_interaction_target_action_provider_base {
	visible = "[SelectInteractionTargetGlue.IsVisible]"
	enabled = "[SelectInteractionTargetGlue.IsEnabled]"

	button_tooltip_override = {
		title = "[SelectInteractionTargetGlue.GetUIActionTitle]"
		description = "[SelectInteractionTargetGlue.GetUIActionDescription]"
		acceptance = "[SelectInteractionTargetGlue.GetUIActionAcceptance]"
		conditions = "[SelectInteractionTargetGlue.GetUIActionConditions]"
		effects = "[SelectInteractionTargetGlue.GetUIActionEffects]"
	}

	action_tooltip = {
		click_type = left
		click_mode = single
		visible = "[SelectInteractionTargetGlue.IsLeftClickVisible]"
		enabled = "[SelectInteractionTargetGlue.IsLeftClickEnabled]"
		title = "[SelectInteractionTargetGlue.GetLeftClickTitle]"
		cost = "[SelectInteractionTargetGlue.GetLeftClickCost]"
		description = "[SelectInteractionTargetGlue.GetLeftClickDescription]"
		effects = "[SelectInteractionTargetGlue.GetLeftClickEffects]"
		conditions = "[SelectInteractionTargetGlue.GetLeftClickConditions]"
		on_action_with_params = "[SelectInteractionTargetGlue.OnLeftClick]"
	}

	action_tooltip = {
		click_type = left
		click_mode = confirm
		visible = "[SelectInteractionTargetGlue.IsLeftClickAndConfirmVisible]"
		enabled = "[SelectInteractionTargetGlue.IsLeftClickAndConfirmEnabled]"
		title = "[SelectInteractionTargetGlue.GetLeftClickAndConfirmTitle]"
		cost = "[SelectInteractionTargetGlue.GetLeftClickAndConfirmCost]"
		description = "[SelectInteractionTargetGlue.GetLeftClickAndConfirmDescription]"
		effects = "[SelectInteractionTargetGlue.GetLeftClickAndConfirmEffects]"
		conditions = "[SelectInteractionTargetGlue.GetLeftClickAndConfirmConditions]"
		on_action_with_params = "[SelectInteractionTargetGlue.OnLeftClickAndConfirm]"
	}

	action_tooltip = {
		click_type = right
		click_mode = single
		visible = "[SelectInteractionTargetGlue.IsRightClickVisible]"
		enabled = "[SelectInteractionTargetGlue.IsRightClickEnabled]"
		title = "[SelectInteractionTargetGlue.GetRightClickTitle]"
		cost = "[SelectInteractionTargetGlue.GetRightClickCost]"
		description = "[SelectInteractionTargetGlue.GetRightClickDescription]"
		effects = "[SelectInteractionTargetGlue.GetRightClickEffects]"
		conditions = "[SelectInteractionTargetGlue.GetRightClickConditions]"
		on_action_with_params = "[SelectInteractionTargetGlue.OnRightClick]"
	}

	action_tooltip = {
		click_type = right
		click_mode = confirm
		visible = "[SelectInteractionTargetGlue.IsRightClickAndConfirmVisible]"
		enabled = "[SelectInteractionTargetGlue.IsRightClickAndConfirmEnabled]"
		title = "[SelectInteractionTargetGlue.GetRightClickAndConfirmTitle]"
		cost = "[SelectInteractionTargetGlue.GetRightClickAndConfirmCost]"
		description = "[SelectInteractionTargetGlue.GetRightClickAndConfirmDescription]"
		effects = "[SelectInteractionTargetGlue.GetRightClickAndConfirmEffects]"
		conditions = "[SelectInteractionTargetGlue.GetRightClickAndConfirmConditions]"
		on_action_with_params = "[SelectInteractionTargetGlue.OnRightClickAndConfirm]"
	}
}

template select_interaction_target_action_provider {
	using = select_interaction_target_action_provider_base
	block "interaction_target_action_provider_tooltip" {
		tooltipwidget = { using = action_tooltip_pop_out }
	}
}

types SelectTarget
{
	type select_target_column_data = icon {
		layoutpolicy_vertical = fixed
		layoutpolicy_horizontal = fixed
		size = "[AttributeColumnData.GetSize('(int32)32')]"
		
		using = tile_card_bg_texture
		using = color_mid_blue

		hbox = {
			size = { 100% 100% }
			spacing = 5

			text_single = {
				layoutpolicy_vertical = fixed
				layoutpolicy_horizontal = expanding
				block "text" {}
			}
		}
	}

	type select_target_column_sort_header = sort_by_button {
		size = "[AttributeColumnData.GetSize('(int32)40')]"
		tooltipwidget = { LeftClickButtonTooltip = { blockoverride "onclick_text" { text = "[AttributeColumnData.GetAttributeName]" } } }

		text_single = {
			position = { 2 3 }
			text = "[AttributeColumnData.GetAttributeName]"
		}
	}

	type select_value_widget = header_paper_card {
		blockoverride "header_paper_card_size" {
			size = { -1 100 }
		}

		blockoverride "header_content" {
			hbox = {
				textbox = {
					size = {-1 35}
					layoutpolicy_horizontal = expanding
					text = "[SelectInteractionTargetGlue.GetSelectTitle]"
					align = center|nobaseline
					default_format = "#high"
				}
			}
		}

		blockoverride "bottom_content" {
			hbox = {
				size = { -1 100 }
				layoutpolicy_horizontal = expanding
				using = bg_text_mask_container_dark_brown
				margin = { 10 0 }
				spacing = 15

				vbox = {
					hbox = {
						spacing = 5
						icon = {
							size = { 24 24 }
							texture = "gfx/interface/icons/resources/bribe.dds"
							texture_density = 2
						}
						text_single = {
							text = "[SelectInteractionTargetGlue.GetValue|2Y]"
						}
					}

					economy_slider = {
						size = { 200 10 }
						min = "[SelectInteractionTargetGlue.GetMinValue]"
						max = "[SelectInteractionTargetGlue.GetMaxValue]"
						step = "[SelectInteractionTargetGlue.GetStep]"
						value = "[SelectInteractionTargetGlue.GetValue]"
						onvaluechanged = "[SelectInteractionTargetGlue.OnValueChanged]"
					}
				}

				button_regular = {
					layoutpolicy_horizontal = expanding
					size = { -1 30 }
					datacontext = "[SelectInteractionTargetGlue.GetValueUIAction]"
					using = button_action_provider
					text = "OK"
					icon = {
						size = { 20 20 }
						parentanchor = right|vcenter
						position = { -5 0 }
						frame_grid = { 3 1 }
						visible = "[And(SelectInteractionTargetGlue.WillAllTargetsBeSelected, SelectInteractionTargetView.RequiresAcceptance)]"
						texture = "gfx/interface/icons/diplomatic_status/ai_accept_decline_icon.dds"
						frame = "[SelectInteractionTargetGlue.GetValueAcceptanceFrame]"
					}
				}
			}
		}
	}

	type transfer_subject_select_price = select_value_widget {
		datacontext = "[SelectInteractionTargetView.GetValueGlue('sale_price')]"
	}
}
