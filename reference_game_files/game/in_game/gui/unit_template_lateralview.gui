lateralview = {
	name = "unit_template_lateralview"
	widgetid = "unit_template_lateralview"

	blockoverride "panel_header" {
		window_header_alt = {
			blockoverride "header_text_object" {
				hbox = {
					header_title = {
						visible = "[And(UnitTemplateLateralView.IsArmy, Not(UnitTemplateLateralView.IsEditingTemplate))]"
						text = "CREATE_ARMY_TEMPLATE"
					}
					header_title = {
						visible = "[And(UnitTemplateLateralView.IsArmy, UnitTemplateLateralView.IsEditingTemplate)]"
						text = "EDIT_ARMY_TEMPLATE"
					}
					header_title = {
						visible = "[And(Not(UnitTemplateLateralView.IsArmy), Not(UnitTemplateLateralView.IsEditingTemplate))]"
						text = "CREATE_NAVY_TEMPLATE"
					}
					header_title = {
						visible = "[And(Not(UnitTemplateLateralView.IsArmy), UnitTemplateLateralView.IsEditingTemplate)]"
						text = "EDIT_NAVY_TEMPLATE"
					}
				}
			}
			blockoverride "window_header_alt_color_texture"{
				using = color_military_texture
			}
		}
	}

	blockoverride "panel_content" {
		vbox = {
			using = layoutpolicy_expanding
			using = bg_main_inner_alt
			using = window_main_tabs_margin_alt
			spacing = 5
			margin_bottom = 25

			editbox_single_alt = {
                name = "unit_template_name_editbox"
                layoutpolicy_horizontal = expanding
                autoresize = no
                size = { -1 32 }
                fontsize = 13
                align = center
                text = "[UnitTemplateLateralView.GetTemplateName]"
                oneditingfinished_with_changes = "[UnitTemplateLateralView.SetTemplateName]"
                focus_on_visible = yes
                alwaystransparent = no
            }

			# Button for obsolete units visibility
			button_check_visibility = {
				size = { 32 32 }

				tooltipwidget = {
					BasicFunctionalTooltip = {}
				}

				action_tooltip = {
					click_type = left
					click_mode = single
					title = "SHOW_OBSOLETE_UNITS"
					on_action = "[UnitTemplateLateralView.ToggleShowOnlyCurrentAge]"
					visible = "[UnitTemplateLateralView.ShowOnlyCurrentAge]"
				}

				action_tooltip = {
					click_type = left
					click_mode = single
					title = "HIDE_OBSOLETE_UNITS"
					on_action = "[UnitTemplateLateralView.ToggleShowOnlyCurrentAge]"
					visible = "[Not(UnitTemplateLateralView.ShowOnlyCurrentAge)]"
				}

				frame = "[Select_int32(Not(UnitTemplateLateralView.ShowOnlyCurrentAge), '(int32)2', '(int32)1')]"
			}
	
			# list of sub units available and what's selected
			scroll_list = {
				using = layoutpolicy_expanding
				alwaystransparent = yes

				blockoverride "scroll_list_is_empty" {
					visible = "[IsDataModelEmpty(UnitTemplateLateralView.GetPossibleSubUnitDefinitions)]"
				}

				blockoverride "scroll_list_content"  {
					addcolumn = 100%
					addrow = 85
					datamodel = "[UnitTemplateLateralView.GetPossibleSubUnitDefinitions]"
					item = {
						widget = {
							size = { 100% 74 }
							hbox = {
								margin = { 3 5 }
								using = bg_paper_card
								
								#UNIT ILLUSTRATION
								widget = {
									size = { 50 65 }		
									datacontext = "[TemplateSubUnitDefinition.GetSubUnitDefinition]"
									
									masked_threecolor_icon = {
										visible = "[Not(TemplateSubUnitDefinition.GetSubUnitDefinition.GetCategory.IsArmy)]"
										texture = "[GetSubunitTypeIllustration(TemplateSubUnitDefinition.GetSubUnitDefinition, TemplateSubUnitDefinition.GetCulture)]"
										size = { 100% 100% }
										texture_density = 2
										spriteborder = { 0 0 }
										frame_grid = {3 1}
										frame = 2
										mask =  "[GetSubunitTypeIllustrationMask(TemplateSubUnitDefinition.GetSubUnitDefinition, TemplateSubUnitDefinition.GetCulture)]"
										primary_color = "[GetCountryUnitPrimaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
										secondary_color = "[GetCountryUnitSecondaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
										tertiary_color = "[GetCountryUnitTertiaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
									}
									
									masked_threecolor_icon = {
										visible = "[TemplateSubUnitDefinition.GetSubUnitDefinition.GetCategory.IsArmy]"
										texture = "[GetSubunitTypeIllustration(TemplateSubUnitDefinition.GetSubUnitDefinition, TemplateSubUnitDefinition.GetCulture)]"
										size = { 100% 100% }
										texture_density = 2
										spriteborder = { 0 0 }
										frame_grid = {3 1}
										frame = 1
										mask =  "[GetSubunitTypeIllustrationMask(TemplateSubUnitDefinition.GetSubUnitDefinition, TemplateSubUnitDefinition.GetCulture)]"
										primary_color = "[GetCountryUnitPrimaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
										secondary_color = "[GetCountryUnitSecondaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
										tertiary_color = "[GetCountryUnitTertiaryColor(TemplateSubUnitDefinition.GetPlayer, TemplateSubUnitDefinition.GetSubUnitDefinition)]"
									}
		
									card_header_button_04 = {
										size = { 100% 100% }
										datacontext = "[TemplateSubUnitDefinition.GetSubUnitDefinition]"
		
										tooltipwidget = {
											using = SubUnitType_tooltip
										}
										action_tooltip = {
											click_type = left
											click_mode = single
											title = "SHOW_UNIT_TYPE"
											on_action = "[ShowUnitType(TemplateSubUnitDefinition.GetSubUnitDefinition)]"
										}
									}	
								}

								vbox = {
									using = layoutpolicy_expanding
									hbox = {
										using = bg_card_header_01
										layoutpolicy_horizontal = expanding
										background = {
											using = bg_card_header_01_default
											alpha = 0.7
										}
										text_single = {
											margin_left = 7
											layoutpolicy_vertical = expanding
											size = { 190 25 }
											autoresize = no
											align = left|nobaseline
											using = Font_Type_Standard
						
											text = "[TemplateSubUnitDefinition.GetSubUnitName]"
										}
		
										expand = {}
		
										widget = {
											size = { 100 30 }
											hbox = {
												margin = {5 0}
												button_minus = {
													size = { 18 18 }
													enabled = "[TemplateSubUnitDefinition.CanDec]"
													action_tooltip = {
														click_type = left
														click_mode = single
														enabled = "[TemplateSubUnitDefinition.CanDec]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanDec, 'TEMPLATE_SUB_UNIT_SUB', 'TEMPLATE_SUB_UNIT_CANNOT_SUB')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)-1')]"
													}
		
													action_tooltip = {
														click_type = left
														click_mode = single
														click_modifier = ctrl
														enabled = "[TemplateSubUnitDefinition.CanDec]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanDec, 'TEMPLATE_SUB_UNIT_SUB_10', 'TEMPLATE_SUB_UNIT_CANNOT_SUB')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)-10')]"
													}
		
													action_tooltip = {
														click_type = left
														click_mode = single
														click_modifier = shift
														enabled = "[TemplateSubUnitDefinition.CanDec]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanDec, 'TEMPLATE_SUB_UNIT_SUB_50', 'TEMPLATE_SUB_UNIT_CANNOT_SUB')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)-50')]"
													}
													tooltipwidget = { BasicFunctionalTooltip = {} }
												}
								
												text_single = {
													size = { 50 20 }
													autoresize = no
													align = center|nobaseline
													raw_text = "#L [TemplateSubUnitDefinition.GetSelection] #!"
													tooltipwidget = {
														SimpleContextualTooltipType = {
															lowpriotextcontext = "TEMPLATE_UNIT_TYPE_SELECTION_TT"
															blockoverride "title_icon" {
																icon = {
																	using = tooltip_title_icon_size
																	texture = "[GetConceptTexture('unit_template')]"
																}
															}
															blockoverride "concept_link" {
																text = "[unit_template|e]"
															}
														}
													}														
												}
		
												button_plus = {
													size = { 18 18 }
													enabled = "[TemplateSubUnitDefinition.CanInc]"
													action_tooltip = {
														click_type = left
														click_mode = single
														enabled = "[TemplateSubUnitDefinition.CanInc]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanInc, 'TEMPLATE_SUB_UNIT_ADD', 'TEMPLATE_SUB_UNIT_CANNOT_ADD')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)1')]"
													}
		
													action_tooltip = {
														click_type = left
														click_mode = single
														click_modifier = ctrl
														enabled = "[TemplateSubUnitDefinition.CanInc]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanInc, 'TEMPLATE_SUB_UNIT_ADD_10', 'TEMPLATE_SUB_UNIT_CANNOT_ADD')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)10')]"
													}
		
													action_tooltip = {
														click_type = left
														click_mode = single
														click_modifier = shift
														enabled = "[TemplateSubUnitDefinition.CanInc]"
														title = "[SelectLocalization(TemplateSubUnitDefinition.CanInc, 'TEMPLATE_SUB_UNIT_ADD_50', 'TEMPLATE_SUB_UNIT_CANNOT_ADD')]"
														on_action = "[TemplateSubUnitDefinition.OnChanged('(int32)50')]"
													}
													tooltipwidget = { BasicFunctionalTooltip = {} }
												}
											}
										}					
									}

									hbox = {
										margin_left = 7
										using = layoutpolicy_expanding
										text_single = {
											text = "[TemplateSubUnitDefinition.GetTotalCost]"
											layoutpolicy_horizontal = expanding
											autoresize = no
											size = { -1 20 }
											fontsize = 13
											align = left|nobaseline
										}

										text_single = {
											visible = "[UnitTemplateLateralView.IsArmy]"
											text = "[TemplateSubUnitDefinition.GetTotalManpower]"
											layoutpolicy_horizontal = expanding
											autoresize = no
											size = { -1 20 }
											fontsize = 13
											align = left|nobaseline
										}

										text_single = {
											visible = "[Not(UnitTemplateLateralView.IsArmy)]"
											text = "[TemplateSubUnitDefinition.GetTotalSailors]"
											layoutpolicy_horizontal = expanding
											autoresize = no
											size = { -1 20 }
											fontsize = 13
											align = left|nobaseline
										}

										text_single = {
											text = "[TemplateSubUnitDefinition.GetTotalMaintenanceCost]"
											layoutpolicy_horizontal = expanding
											autoresize = no
											size = { -1 20 }
											fontsize = 13
											align = left|nobaseline
										}

										# text_single = {
										# 	visible = "[GreaterThan_float(TemplateSubUnitDefinition.GetSelection, '(float)0')]"
										# 	text = "[TemplateSubUnitDefinition.GetEstimatedConstructionTime]"
										# 	layoutpolicy_horizontal = expanding
										# 	autoresize = no
										# 	size = { -1 20 }
										# 	fontsize = 13
										# 	align = left|nobaseline
										# }
									}
								}
							}
							widget = {
								size = { 100% 102% }
								using = bg_cabinet_card_frame
								ignore_layout = yes
							}
						}
					}
				}
			}

			# template information
			widget = {
				layoutpolicy_horizontal = expanding
				size = { -1 150 }
				using = bg_paper_card

				vbox = {
					# COSTS
					hbox = {
						layoutpolicy_horizontal = expanding
						widget = {
							layoutpolicy_horizontal = expanding
							size = { -1 45 }
							using = bg_card_header_01
							background = {
								using = bg_card_header_01_default
								alpha = 0.7
							}
							hbox = {
								spacing = 10
								margin = { 15 0 }
								# Gold Cost
								widget = {
									using = layoutpolicy_expanding
									hbox = {
										margin = {5 7}
										spacing = 5
										icon = {
											size = {25 25}
											texture = "[GetConceptTexture('gold')]"
										}
										vbox = {
											using = layoutpolicy_expanding
											text_single = {
												layoutpolicy_horizontal = expanding
												size = { -1 15 }
												fontsize = 13
												autoresize = no
												align = left|nobaseline
												text = "[price|e]"
											}
											text_single = {
												text = "[UnitTemplateLateralView.GetTotalCost]"
												layoutpolicy_horizontal = expanding
												autoresize = no
												size = { -1 20 }
												align = left|nobaseline
											}
										}
									}
								}

								# Sailors Cost
								widget = {
									using = layoutpolicy_expanding
									visible = "[Not(UnitTemplateLateralView.IsArmy)]"
									hbox = {
										margin = {5 7}
										spacing = 5
										icon = {
											size = {25 25}
											texture = "[GetConceptTexture('sailors')]"
										}
										vbox = {
											using = layoutpolicy_expanding
											text_single = {
												layoutpolicy_horizontal = expanding
												size = { -1 15 }
												fontsize = 13
												autoresize = no
												align = left|nobaseline
												text = "[sailors|e]"
											}
											text_single = {
												text = "[UnitTemplateLateralView.GetTotalSailors]"
												layoutpolicy_horizontal = expanding
												autoresize = no
												size = { -1 20 }
												align = left|nobaseline
											}
										}
									}
								}

								# Manpower Cost
								widget = {
									using = layoutpolicy_expanding
									visible = "[UnitTemplateLateralView.IsArmy]"
									hbox = {
										margin = {5 7}
										spacing = 5
										icon = {
											size = {25 25}
											texture = "[GetConceptTexture('manpower')]"
										}
										vbox = {
											using = layoutpolicy_expanding
											text_single = {
												layoutpolicy_horizontal = expanding
												size = { -1 15 }
												fontsize = 13
												autoresize = no
												align = left|nobaseline
												text = "[manpower|e]"
											}
											text_single = {
												text = "[UnitTemplateLateralView.GetTotalManpower]"
												layoutpolicy_horizontal = expanding
												autoresize = no
												size = { -1 20 }
												align = left|nobaseline
											}
										}
									}
								}

								# Maintenance Cost
								widget = {
									using = layoutpolicy_expanding
									hbox = {
										margin = {5 7}
										spacing = 5
										icon = {
											size = {25 25}
											texture = "[GetConceptTexture('maintenance')]"
										}
										vbox = {
											using = layoutpolicy_expanding
											text_single = {
												layoutpolicy_horizontal = expanding
												size = { -1 15 }
												fontsize = 13
												autoresize = no
												align = left|nobaseline
												text = "[maintenance|e]"
											}
											text_single = {
												text = "[UnitTemplateLateralView.GetTotalMaintenanceCost]"
												layoutpolicy_horizontal = expanding
												autoresize = no
												size = { -1 20 }
												align = left|nobaseline
											}
										}
									}
								}

								# # Estimated Time
								# widget = {
								# 	using = layoutpolicy_expanding
								# 	hbox = {
								# 		margin = {5 0}
								# 		spacing = 5
								# 		icon = {
								# 			size = {25 25}
								# 			texture = "[GetConceptTexture('construction')]"
								# 		}
								# 		vbox = {
								# 			using = layoutpolicy_expanding
								# 			text_single = {
								# 				layoutpolicy_horizontal = expanding
								# 				size = { -1 15 }
								# 				fontsize = 13
								# 				autoresize = no
								# 				align = left|nobaseline
								# 				text = "[construction|e]"
								# 			}
								# 			text_single = {
								# 				text = "[UnitTemplateLateralView.GetEstimatedConstructionTime]"
								# 				layoutpolicy_horizontal = expanding
								# 				autoresize = no
								# 				size = { -1 20 }
								# 				align = left|nobaseline
								# 			}
								# 		}
								# 	}
								# }
							}
						}
					}

					# CATEGORIES INCLUDED
					hbox = {
						margin_top = 4
						margin_bottom = 7
						using = layoutpolicy_expanding
						hbox = {
							spacing = 30
							SubUnitTemplateCategoryCard = {
								visible = "[UnitTemplateLateralView.IsArmy]"
								datacontext = "[GetSubUnitCategory('army_infantry')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[UnitTemplateLateralView.IsArmy]"
								datacontext = "[GetSubUnitCategory('army_cavalry')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[UnitTemplateLateralView.IsArmy]"
								datacontext = "[GetSubUnitCategory('army_artillery')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[UnitTemplateLateralView.IsArmy]"
								datacontext = "[GetSubUnitCategory('army_auxiliary')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[Not(UnitTemplateLateralView.IsArmy)]"
								datacontext = "[GetSubUnitCategory('navy_transport')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[Not(UnitTemplateLateralView.IsArmy)]"
								datacontext = "[GetSubUnitCategory('navy_galley')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[Not(UnitTemplateLateralView.IsArmy)]"
								datacontext = "[GetSubUnitCategory('navy_light_ship')]"
							}
							SubUnitTemplateCategoryCard = {
								visible = "[Not(UnitTemplateLateralView.IsArmy)]"
								datacontext = "[GetSubUnitCategory('navy_heavy_ship')]"
							}
						}
					}
				}
				widget = {
					size = { 100% 100% }
					using = bg_cabinet_card_frame
					ignore_layout = yes
				}
			}

			# create template button
			card_header_button_01 = {
				name = "create_template_button"
				layoutpolicy_horizontal = expanding
				size = {-1 30}

				using = bg_paper_card
				using = bg_card_header_01_military

				tooltipwidget = {
					basicfunctionaltooltip = {}
				}

				text_single = {
					visible = "[Not(UnitTemplateLateralView.IsEditingTemplate)]"
					text = "CREATE_UNIT_TEMPLATE"
					autoresize = no
					align = center
					size = { 100% 30 }
				}

				text_single = {
					visible = "[UnitTemplateLateralView.IsEditingTemplate]"
					text = "FINISH_EDIT_UNIT_TEMPLATE"
					autoresize = no
					align = center
					size = { 100% 30 }
				}

				enabled = "[UnitTemplateLateralView.CanCreateTemplate]"
				action_tooltip = {
					click_type = left
					click_mode = single
					title = "CREATE_UNIT_TEMPLATE"
					on_action = "[UnitTemplateLateralView.CreateTemplate]"
					enabled = "[UnitTemplateLateralView.CanCreateTemplate]"
					conditions = "[UnitTemplateLateralView.CanCreateTemplateInfo]"
				}
			}
		}
	}
}

types UnitTemplateTypes
{
	# type SubUnitCategoryButton = button {
	# 	size = { 20 20 }
	# 	texture = "[GetSubUnitCategoryIcon(SubUnitCategory.Self)]"
	# 	onclick = "[DetachCategory(UnitItem.GetUnit.Self,SubUnitCategory.Self)]"
	# 	block "subunitcategory_tooltip" {
	# 		tooltip = "[GetDetachCategoryInfo(UnitItem.GetUnit.Self,SubUnitCategory.Self,'(bool)yes')]"
	# 	}
	# 	enabled = "[CanDetachCategory(UnitItem.GetUnit.Self,SubUnitCategory.Self)]"
	# 	visible = "[GreaterThan_int32(SubUnitCategory.GetCount(UnitItem.GetUnit.Self), '(int32)0')]"
	# 	texture_density = 2
	# }

	type SubUnitTemplateCategoryCard = SubUnitCategoryCard
	{
		blockoverride "unit_template_subunit_category_amount" {
			text = "[UnitTemplateLateralView.GetSubUnitCategoryAmount(SubUnitCategory.Self)]"
		}
	}

	type UnitTemplateCard = widget {
		size = { 100% 85 }
		widget = {
			size = { 99% 74 }
			parentanchor = center

			hbox = {
				margin = { 1 0 }

				hbox = {
					layoutpolicy_horizontal = expanding
					using = bg_paper_card
					margin = {3 0}

					widget = {
						layoutpolicy_vertical = expanding
						size = {50 -1}

						icon = {
							parentanchor = center
							size = {50 50}
							texture = "[GetConceptTexture('unit_template')]"
						}
						icon = {
							ignore_layout = yes
							parentanchor = center
							size = {100% 100%}
							texture = "gfx/interface/component_masks/mask_events_texture_full.dds"
							spriteType = corneredstretched
							spriteborder = {60 60}
							texture_density = 2
							alpha = 0.6
							modify_texture = {
								using = color_dark_brown_texture
							}
						}
						tooltipwidget = {
							using = UnitTemplate_tooltip
						}
					}

					vbox = {
						layoutpolicy_horizontal = expanding

						widget = {
							layoutpolicy_horizontal = expanding
							size = { -1 65 }

							clickable_header_card = {
								parentanchor = vcenter

								blockoverride "bg_card_header_01_bg" {
									background = {
										visible = "[UnitTemplate.IsArmy]"
										using = bg_card_header_01_default
										alpha = 0.3
									}
						
									background = {
										visible = "[Not(UnitTemplate.IsArmy)]"
										using = bg_card_header_01_default
										alpha = 0.5
										blockoverride "header_color" {
										using = color_military_texture
										}
									}
								}
								blockoverride "card_bg" {}
										
								blockoverride "clickable_header_card_size"{
									size = { 100% 65 }
								}
								blockoverride "header_size" {
									size = { -1 35 }
								}
								blockoverride "header_button" {
									hbox = {
										margin_left = 1
										spacing = 1
										widget = {
											layoutpolicy_horizontal = expanding
											size = { -1 35 }
											using = bg_card_header_01
											blockoverride "bg_card_header_01_bg" {
												background = {
													using = bg_card_header_01_default
													alpha = 0.7
												}
											}
											
											blockoverride "header_pattern_texture_density" {texture_density = 1.75}
											blockoverride "header_pattern_alpha" { alpha = 0.5 }

											hbox = {
												margin_right = 4
												spacing = 5

												card_header_button_01 = {
													name = "unit_template_button"
													layoutpolicy_horizontal = expanding
													size = {-1 30}
								
													using = bg_paper_card
													using = bg_card_header_01_military
					
													tooltipwidget = {
														using = UnitTemplate_tooltip
													}
					
													text_single = {
														text = "[UnitTemplate.GetNameWithNoTooltip]"
														autoresize = no
														align = center
														parentanchor = center
														size = { 100% 30 }
													}

													# text_single = {
													# 	layoutpolicy_horizontal = expanding
													# 	autoresize = no
													# 	size = {-1 20}
													# 	align = left|nobaseline
													# 	using = Font_Type_Headers
													# 	using = Font_Size_Small
													# 	text = "[UnitTemplate.GetNameWithNoTooltip]"
