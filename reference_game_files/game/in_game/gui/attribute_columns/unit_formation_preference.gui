types UnitFormationPreferences
{
	type unit_formation_preference_name = clickable_header_card {
		blockoverride "layout_setup" {
			using = flexible_interaction_target_entry_setup
		}

		blockoverride "header_size" {
			size = { -1 25 }
		}
		blockoverride "header_color" {
			using = color_government_texture
		}

		blockoverride "header_content" {
			using = select_interaction_target_action_provider
			datacontext = "[InteractionTarget.GetUnitFormationPreference]"
			tooltipwidget = {
				using = UnitFormationPreference_tooltip
			}

			hbox = {
				margin_right = 10
				spacing = 10
				layoutpolicy_horizontal = expanding

				estate_privilege_action_button_alt = {
					size = { 25 25 }
					blockoverride "icon_texture" {
						texture = "[GetUnitFormationPreferenceIcon(InteractionTarget.GetUnitFormationPreference)]"
					}
					blockoverride "estate_privilege_button_action" {
						tooltip_enabled = no
						using = select_interaction_target_action_provider
					}
				}

				text_single = {
					using = layoutpolicy_expanding
					using = Font_Size_Medium
					default_format = "#yellow_titles"
					autoresize = no
					size = { 200 18 }
					multiline = yes
					align = nobaseline
					text = "[InteractionTarget.GetUnitFormationPreference.GetNameWithNoTooltip]"

					sort_by_left_fade_highlight = {
						name = "name"
					}
				}
				
				
			}
		}

		blockoverride "bottom_content_layout" {
			vbox = {
				using = bg_paper_card

				
				layoutpolicy_horizontal = expanding
				spacing = 5
				margin = { 5 5 }

				card_stringpair_list = {
					textcontext =  "[InteractionTarget.GetUnitFormationPreference.GetCondensedTooltip]"
				}
			}
		}
	}
}