# this must be in sync with outliner.gui and message_log.gui
@topbar_height = 40
@panel_bar_height = 90
@left_panel_width = 570
@panel_x = 0

types cmf_action_bar {

    type cmf_action_bar_bottom_left = cmf_action_bar_bottom {
        visible = "[And3(
            Not(LeftView.IsShown),
            Not(GetVariableSystem.Exists('cmf_hide_action_bar')),
            GetScriptedGui('sgui_cmf_setting_action_bar_position').IsShown(GuiScope
                .SetRoot(GetPlayer.MakeScope)
                .AddScope('position', MakeScopeValue(GetPlayer.MakeScope.ScriptValue('cmf_action_bar_bottom_left')))
                .End
            )
        )]"
        position = { 300 0 }
        parentanchor = bottom|left
    }

    type cmf_action_bar_bottom_right = cmf_action_bar_bottom {
        visible = "[And3(
            Not(RightView.IsShown),
            Not(GetVariableSystem.Exists('cmf_hide_action_bar')),
            Or(
                Not(GetPlayer.MakeScope.Var('cmf_action_bar_position').IsSet),
                GetScriptedGui('sgui_cmf_setting_action_bar_position').IsShown(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .AddScope('position', MakeScopeValue(GetPlayer.MakeScope.ScriptValue('cmf_action_bar_bottom_right')))
                    .End
                )
            )
        )]"
        position = { -300 0 }
        parentanchor = bottom|right
    }

    type cmf_action_bar_top = cmf_action_bar_top_tabs {
        visible = "[And3(
            Not(LeftView.IsShown),
            Not(GetVariableSystem.Exists('cmf_hide_action_bar')),
            GetScriptedGui('sgui_cmf_setting_action_bar_position').IsShown(GuiScope
                .SetRoot(GetPlayer.MakeScope)
                .AddScope('position', MakeScopeValue(GetPlayer.MakeScope.ScriptValue('cmf_action_bar_top')))
                .End
            )
        )]"
    }

    type cmf_action_bar_bottom = hbox {
        minimumsize = { -1 40 }
        maximumsize = { -1 40 }
        using = bg_mapmenu_tab
        using = Animation_Show_Hide_UI
        alwaystransparent = no
        allow_outside = yes
        filter_mouse = left|right

        icon = {
            using = left_decoration_icon
            size = { 50 40 }
        }

        cmf_action_bar_horizontal = {}

        icon = {
            using = right_decoration_icon
            size = { 50 40 }
        }
    }

    type cmf_action_bar_horizontal = hbox {
        margin = { 10 3 }
        spacing = 4
        set_parent_size_to_minimum = yes

        hbox = {
            spacing = 4
            datamodel = "[GetPlayer.MakeScope.GetList('cmf_action_bar_active_elements')]"
            visible = "[DataModelHasItems(GetPlayer.MakeScope.GetList('cmf_action_bar_active_elements'))]"

            item = {
                widget = {
                    size = { 34 34 }
                    visible = "[Or(
                        Not(GreaterThan_CFixedPoint(GetPlayer.MakeScope.GetVariableFromVariableMap('cmf_has_sgui', MakeScopeFlag(Scope.GetFlagName)).GetValue, '(CFixedPoint)0')),
                        GetScriptedGui(Scope.GetFlagName).IsShown(GuiScope
                            .SetRoot(GetPlayer.MakeScope)
                            .End
                        )
                    )]"

                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'blue')]"
                        blockoverride "base_color" {
                            using = color_blue_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'bone')]"
                        blockoverride "base_color" {
                            using = color_bone_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'brown_leather')]"
                        blockoverride "base_color" {
                            using = color_brown_leather_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'intense_bg_blue')]"
                        blockoverride "base_color" {
                            using = color_intense_bg_blue_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'dark_turquoise')]"
                        blockoverride "base_color" {
                            using = color_dark_turquoise_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'gold')]"
                        blockoverride "base_color" {
                            using = color_gold_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'gold_dark')]"
                        blockoverride "base_color" {
                            using = color_gold_dark_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'grey')]"
                        blockoverride "base_color" {
                            using = color_grey_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'intense_brown')]"
                        blockoverride "base_color" {
                            using = color_intense_brown_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'light_blue')]"
                        blockoverride "base_color" {
                            using = color_light_blue_texture
                        }
                    }
                    cmf_action_bar_button = {
                        visible = "[EqualTo_string(Localize(Concatenate(Scope.GetFlagName, '_color')), 'bronze')]"
                        blockoverride "base_color" {
