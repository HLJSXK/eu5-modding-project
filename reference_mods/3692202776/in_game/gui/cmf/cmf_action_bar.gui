        cmf_action_bar_button = {
            blockoverride "visibility" {
                visible = "[InDebugMode]"
            }
            blockoverride "base_color" {
                using = color_dark_red_texture
            }
            blockoverride "icon" {
                icon = {
                    size = { 20 20 }
                    parentanchor = center
                    texture = "gfx/interface/icons/flat_icons/tabicons/hints.dds"
                }
            }
            blockoverride "action" {
                on_action = "[AccessLogViewer.OpenLinkedLogViewer]"
            }
            blockoverride "action_bar_button_tooltip" {
                tooltipwidget = {
                    ContextualTooltipType = {
                        blockoverride "title_text" {
                            text = "cmf_action_bar_log_viewer_tooltip_title"
                        }
                        blockoverride "tooltip_content" {
                            TooltipTextBlock = {
                                blockoverride "text" {
                                    text = "cmf_action_bar_log_viewer_tooltip_text"
                                }
                            }
                        }
                    }
                }
            }
        }

        cmf_action_bar_button = {
            blockoverride "visibility" {}
            blockoverride "base_color" {
                using = color_dark_purple_texture
            }
            blockoverride "icon" {
                icon = {
                    size = { 20 20 }
                    parentanchor = center
                    texture = "gfx/interface/icons/flat_icons/tabicons/settings_flat_icon.dds"
                }
            }
            blockoverride "action" {
                on_action = "[GetVariableSystem.Toggle('cmf_settings')]"
            }
            blockoverride "action_bar_button_tooltip" {
                tooltipwidget = {
                    ContextualTooltipType = {
                        blockoverride "title_text" {
                            text = "cmf_action_bar_settings_tooltip_title"
                        }
                        blockoverride "tooltip_content" {
                            TooltipTextBlock = {
                                blockoverride "text" {
                                    text = "cmf_action_bar_settings_tooltip_text"
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    type cmf_action_bar_top_tabs = hbox {
        maximumsize = { 570 35 }
        minimumsize = { 570 35 }
        position = { 0 @[topbar_height + panel_bar_height] }
        parentanchor = top|left

        state = {
            name = hide_ui
            using = Animation_Show_Hide_Properties

            position_x = @[-left_panel_width]
            alpha = 0
            start_sound = { soundeffect = "UI_gameStart_gui_out" }
        }
        state = {
            name = show_ui
            using = Animation_Show_Hide_Properties

            position_x = @panel_x
            alpha = 1
            start_sound = { soundeffect = "UI_gameStart_gui_in" }
        }

        datamodel = "[GetPlayer.MakeScope.GetList('cmf_action_bar_active_elements')]"

        cmf_action_tab_button = {
            blockoverride "visibility" {
                visible = "[InDebugMode]"
            }
            blockoverride "base_color" {
                using = color_dark_red_texture
            }
            blockoverride "icon" {
                icon = {
                    size = { 20 20 }
                    parentanchor = center
                    texture = "gfx/interface/icons/flat_icons/tabicons/hints.dds"
                }
            }
            blockoverride "action" {
                on_action = "[AccessLogViewer.OpenLinkedLogViewer]"
            }
            blockoverride "action_bar_button_tooltip" {
                tooltipwidget = {
                    ContextualTooltipType = {
                        blockoverride "title_text" {
                            text = "cmf_action_bar_log_viewer_tooltip_title"
                        }
                        blockoverride "tooltip_content" {
                            TooltipTextBlock = {
                                blockoverride "text" {
                                    text = "cmf_action_bar_log_viewer_tooltip_text"
                                }
                            }
                        }
                    }
                }
            }
        }

        cmf_action_tab_button = {
            blockoverride "visibility" {}
            blockoverride "base_color" {
                using = color_dark_purple_texture
            }
            blockoverride "icon" {
                icon = {
                    size = { 20 20 }
                    parentanchor = center
                    texture = "gfx/interface/icons/flat_icons/tabicons/settings_flat_icon.dds"
                }
            }
            blockoverride "action" {
                on_action = "[GetVariableSystem.Toggle('cmf_settings')]"
            }
            blockoverride "action_bar_button_tooltip" {
                tooltipwidget = {
                    ContextualTooltipType = {
                        blockoverride "title_text" {
                            text = "cmf_action_bar_settings_tooltip_title"
                        }
                        blockoverride "tooltip_content" {
                            TooltipTextBlock = {
                                blockoverride "text" {
                                    text = "cmf_action_bar_settings_tooltip_text"
                                }
                            }
                        }
                    }
                }
            }
        }

        item = {
            cmf_action_tab_button = {
            }
        }
    }

    type cmf_action_bar_button = button {
        size = { 34 34 }
        block "visibility" {
            enabled = "[Or(
                Not(GreaterThan_CFixedPoint(GetPlayer.MakeScope.GetVariableFromVariableMap('cmf_has_sgui', MakeScopeFlag(Scope.GetFlagName)).GetValue, '(CFixedPoint)0')),
                GetScriptedGui(Scope.GetFlagName).IsValid(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .End
                )
            )]"
        }

        using = paper_card_texture
        modify_texture = {
            block "base_color" {
                using = color_wood_brown_texture
            }
            blend_mode = add
        }
        modify_texture = {
            using = paper_03_texture
            blend_mode = overlay
            alpha = 0.3
        }

        action_tooltip = {
            click_type = left
            title = cmf_action_bar_open_action
            block "action" {
                on_action = "[GetScriptedGui('cmf_auto_action_bar_clicked').Execute(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .AddScope('element', MakeScopeFlag(Scope.GetFlagName))
                    .End
                )]"
            }
        }

        block "action_bar_button_tooltip" {
            tooltipwidget = {
                ContextualTooltipType = {
                    lowpriotextcontext = "[Scope.GetFlagName]"
                    ontextcontextchanged = "[SetCStringFromTextContext(PdxGuiWidget.AccessSelf)]"
                    blockoverride "title_text" {
                        text = "[Localize(Concatenate(CString.GetString, '_name'))]"
                    }
                    blockoverride "tooltip_content" {
                        TooltipTextBlock = {
                            blockoverride "text" {
                                text = "[Localize(Concatenate(CString.GetString, '_tooltip'))]"
                            }
                        }
                    }
                }
            }
        }

        block "icon" {
            textbox = {
                size = { 20 20 }
                parentanchor = center
                align = center
                text = "[Localize(Concatenate(Scope.GetFlagName, '_icon'))]"
            }
        }
    }

    type cmf_action_tab_button = button_panel_tab_alt {
        using = layoutpolicy_expanding
        block "visibility" {
            visible = "[Or(
                Not(GreaterThan_CFixedPoint(GetPlayer.MakeScope.GetVariableFromVariableMap('cmf_has_sgui', MakeScopeFlag(Scope.GetFlagName)).GetValue, '(CFixedPoint)0')),
                GetScriptedGui(Scope.GetFlagName).IsShown(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .End
                )
            )]"
            enabled = "[Or(
                Not(GreaterThan_CFixedPoint(GetPlayer.MakeScope.GetVariableFromVariableMap('cmf_has_sgui', MakeScopeFlag(Scope.GetFlagName)).GetValue, '(CFixedPoint)0')),
                GetScriptedGui(Scope.GetFlagName).IsValid(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .End
                )
            )]"
        }

        action_tooltip = {
            click_type = left
            title = cmf_action_bar_open_action
            block "action" {
                on_action = "[GetScriptedGui('cmf_auto_action_bar_clicked').Execute(GuiScope
                    .SetRoot(GetPlayer.MakeScope)
                    .AddScope('element', MakeScopeFlag(Scope.GetFlagName))
                    .End
                )]"
            }
        }

        block "action_bar_button_tooltip" {
            tooltipwidget = {
                ContextualTooltipType = {
                    lowpriotextcontext = "[Scope.GetFlagName]"
                    ontextcontextchanged = "[SetCStringFromTextContext(PdxGuiWidget.AccessSelf)]"
                    blockoverride "title_text" {
                        text = "[Localize(Concatenate(CString.GetString, '_name'))]"
                    }
                    blockoverride "tooltip_content" {
                        TooltipTextBlock = {
                            blockoverride "text" {
                                text = "[Localize(Concatenate(CString.GetString, '_tooltip'))]"
                            }
                        }
                    }
                }
            }
        }

        block "icon" {
            textbox = {
                size = { 20 20 }
                parentanchor = center
                align = center
                text = "[Localize(Concatenate(Scope.GetFlagName, '_icon'))]"
            }
        }
    }

}