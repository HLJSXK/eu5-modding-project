##########################################################################################################################

###################################################
###### Idea dip_1
###################################################

template iv_2_tooltip_template_idea_dip_1_1 {
	
	
	ContextualTooltipType = {
		blockoverride "title_icon" {
			icon = {
				using = tooltip_title_icon_size
				texture = "gfx/interface/icon_idea_dip.dds"

				glow = {
					name = "drop_shadow"
					glow_radius = 3
					color = {0.0 0.0 0.0 1.0}
					alpha = 0.3
				}
			}
		}
		
		blockoverride "title_text" {
			text = "iv2_ideagroup_title_text_dip_1_1"
		}
		
		blockoverride "concept_link" {
			text = "iv2_ideagroup_concept_link_dip_1"
		}
	}
}

