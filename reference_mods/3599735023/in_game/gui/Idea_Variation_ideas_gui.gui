											datacontext = "[Player.GetTimedModifierOwner]"
										}

									}
								}
								
								button_default = {							
									datacontext = "[GetScriptedGui('iv2_get_debug_event')]"
									onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer .MakeScope ).End )]"
									visible = "[InDebugMode]"
									
									size = { 30 40 }
									
									
									hbox = {
