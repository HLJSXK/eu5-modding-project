###### Idea Categories 
###################################################
###################################################				
				hbox = {		

					layoutpolicy_horizontal = expanding
					

						widget = {
							size = {
								25
								25
							}
							background = {
								using = color_dark_brown_texture
								using = overlay_window
								using = overlay_leather
							}
							layoutpolicy_horizontal = expanding
							textbox = {
								block
								"header"
								{
									text = "IV2_ADM_HEADER"
								}
								size = {
									100%
									100%
								}
								align = center|nobaseline
								using = fontsize_large
								default_format = "#overview_text"
								elide = right
							}			
					}
					widget = {
						size = {
							25
							25
						}
						background = {
