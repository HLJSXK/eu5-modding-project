											name = "reload_gui_button_text"
											text = "IV_DEBUG_GUI_TEXT"
										}
									}
								}
								
								button_default = {							
									datacontext = "[GetScriptedGui('iv2_gui_reload_gui_all')]"
									
									onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer .MakeScope ).End )]"
									
									onrightclick = "[ExecuteConsoleCommand('debug_mode')]"
									size = { 90 40 }
									
									tooltipwidget = {
