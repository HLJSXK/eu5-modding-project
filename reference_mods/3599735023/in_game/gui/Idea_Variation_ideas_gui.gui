		scrollbox = {
			using = layoutpolicy_expanding
			using = bg_secondary_inner_alt

			blockoverride "scrollbox_content" {
			
				vbox = {
					using = layoutpolicy_expanding
					
						hbox = {
							spacing = -4
							using = layoutpolicy_expanding
							layoutpolicy_horizontal = expanding
							
							widget = {
								size = { -1 820 } #494 820
								layoutpolicy_horizontal = expanding
								icon = {
									size = { 100% 100% }
									parentanchor = left
									texture = "gfx/interface/iv2_idea_category_template.dds"
								}
								
								character_frame_small = {
									parentanchor = left
									position = { 15 15 }
									blockoverride "portrait_datacontext" {
													
										datacontext =  "[Country.MakeScope.GetVariable('Iv2_researcher_adm').GetCharacter]"
									
									}
									block "character_frame_size" {
										size = { 160 160 }
									}
									blockoverride "character_frame_texture" {
										texture = "gfx/interface/component_decoration/character_frames/character_non_stretchable_frame_2.dds"
									}
									blockoverride "character_portrait_visible" {
										visible = yes
									}
									blockoverride "character_portrait_ani_visible" {
										visible = no
									}
								}
								
								###################################################
								###### Researcher Text Adm
								###################################################	
								text_single = {
									text = "IV2_ADM_RESEARCHER_NAME"
