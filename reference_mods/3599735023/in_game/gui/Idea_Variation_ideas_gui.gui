##########################################################################################################################
##########################################################################################################################
####### Idea Window by flogi
##########################################################################################################################
##########################################################################################################################

window = {
	
	

    name = "ideas_window"
	
	datacontext = "[GetPlayer]"
	datacontext = "[GetVariableSystem]"
	parentanchor = center
	size = { 100% 100% }
	alwaystransparent = yes
	
	 # Initialize variables when window opens
    oncreate = "[GetVariableSystem.Set( 'iv2_var_system_tabs', 'iv2_tabs_ideagroups' )]"
		
	vbox = {
            using = lateralview_full_margins
	
            # Window header with close button
            widget = {
                layoutpolicy_horizontal = expanding
                size = { 0 40 }
                using = bg_lateralview
				allow_outside = yes
		
				vbox = {
					block "panel_header" {}

					hbox = {
						using = layoutpolicy_expanding

						widget = {
							using = layoutpolicy_expanding
							block "panel_content" {}
						}

					}
				}
				
                # Close button
                button_close_alt = {
                    parentanchor = right|vcenter
                    position = { -10 0 }
                    blockoverride "close_onclick" {
						onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets ideas_window')]"
                    }
                }
            }
			
###################################################
###################################################
###### Panel Name
###################################################
###################################################			
			blockoverride "panel_header" {
				window_header_alt = {
					blockoverride "header_text"
					{
						text = "IV2_INTERFACE_IDEAS_HEADER"
					}
				}
			}
	

###################################################
###################################################
###### Panel Tabs 
###################################################
###################################################
			
			header_secondary_tabs = {
				size = {-1 40 }
				background = {
					using = button_secondary_tab_alt_color
					using = button_main_tab_icon_texture
				}
				blockoverride "content" {
					button_secondary_tab_alt = {
						using = layoutpolicy_expanding
						text = "IV2_INTERFACE_IDEAGROUPS_HEADER"
						onclick = "[GetVariableSystem.Set( 'iv2_var_system_tabs', 'iv2_tabs_ideagroups' )]"
						down = "[GetVariableSystem.HasValue( 'iv2_var_system_tabs', 'iv2_tabs_ideagroups' )]"
					}
					button_secondary_tab_alt = {
						using = layoutpolicy_expanding
						text = "IV2_INTERFACE_NAT_IDEAS_HEADER"
						datacontext = "[GetScriptedGui('iv2_gui_reload_gui_me')]" # Deactivated
						enabled = "[GetScriptedGui('iv2_gui_reload_gui_me').IsValid(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
						onclick = "[GetVariableSystem.Set( 'iv2_var_system_tabs', 'iv2_tabs_nationalideas' )]"
						down = "[GetVariableSystem.HasValue( 'iv2_var_system_tabs', 'iv2_tabs_nationalideas' )]"
					}

					button_secondary_tab_alt = {
						using = layoutpolicy_expanding
						text = "IV2_INTERFACE_STATS_HEADER"
						onclick = "[GetVariableSystem.Set( 'iv2_var_system_tabs', 'iv2_tabs_statistics' )]"
						down = "[GetVariableSystem.HasValue( 'iv2_var_system_tabs', 'iv2_tabs_statistics' )]"
					}
				}
			}
			

###################################################
###################################################
###### Ideagroup Area Start
###################################################
###################################################
			
           
            vbox = {
                layoutpolicy_horizontal = expanding
				using = layoutpolicy_expanding
                using = bg_main_inner_alt
				visible = "[GetVariableSystem.HasValue( 'iv2_var_system_tabs', 'iv2_tabs_ideagroups' )]"
							
				
###################################################
###################################################
###### Modifier Bar
###################################################
###################################################
				
				
				hbox = {		
			position = { 0 -320 }
					layoutpolicy_horizontal = expanding
					maximumsize = { -1 -1 }

					widget = {
						parentanchor = left
							size = { 50 50 }
							
							background = {
								using = color_dark_blue_texture
								
							}
							layoutpolicy_horizontal = expanding
							
							hbox = {
								background = {
									using = color_dark_blue_texture
								}	
								
								stat_player = {
									name = "iv2_stat_innovation_adm"
									using = layoutpolicy_expanding
									margin = { 5 0 }
									maximumsize = { 100 -1 }
									
									tooltipwidget = {
									using = iv_scrollbar_adm_tooltip_template
									}

									icon = {
										size = { 24 24 }
										texture = "gfx/interface/icon_innovation_points_adm.dds"
										texture_density = 2
									}
									
									
									vbox = {
										hbox = {
											margin = { 5 0 }
											text_single = {
												name = "iv2_text"
												text = "IV2_IDEA_STATBAR_INNOVATION_ADM"
											}
										}
										progressbar = {
											size = { 120 8 }
											using = progress_bar_blue_grey_alt
											min = 0
											max = "[FixedPointToFloat(Country.MakeScope.Var('iv2_var_innovation_points_limit_adm').GetValue)]"
										   
											value = "[FixedPointToFloat(Country.MakeScope.Var('iv2_var_innovation_points_adm').GetValue)]"
											noprogresstexture = "gfx/interface/progressbars/progress_gray_bg.dds"
											block "progress_setup" {}											
										}
									}
									
									icon = {
										size = { 24 24 }
										texture = "gfx/interface/icon_innovation_points_max_adm.dds"
										texture_density = 2
									}
									
									
									expand = {}
								}
								
								stat_player = {
									name = "iv2_stat_innovation_dip"
									using = layoutpolicy_expanding
									margin = { 5 0 }
									maximumsize = { 100 -1 }
									
									tooltipwidget = {
