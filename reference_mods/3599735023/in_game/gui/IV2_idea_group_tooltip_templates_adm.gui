	SimpleContextualTooltipType = {
		blockoverride "title_icon" {
			icon = {
				using = tooltip_title_icon_size
				texture = "[GetModifier('ideagroup_modifier_adm_54_1').GetIcon]"

				glow = {
					name = "drop_shadow"
					glow_radius = 3
					color = {0.0 0.0 0.0 1.0}
					alpha = 0.3
				}
			}
		}

		blockoverride "title_text" {
			text = "STATIC_MODIFIER_NAME_ideagroup_modifier_adm_54_1"
		}

		blockoverride "tooltip_content" {
			
			
			TooltipFlavorTextBlock = {
				visible = "[Not(StringIsEmpty(GetModifier('ideagroup_modifier_adm_54_1').GetDesc))]"
				blockoverride "text" {
					text = "[GetModifier('ideagroup_modifier_adm_54_1').GetDesc]"
				}
			}
		}
	}
}

