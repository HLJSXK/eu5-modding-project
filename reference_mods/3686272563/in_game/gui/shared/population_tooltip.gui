template CountryEstatesPowerTooltip {
	ContextualTooltipType = {
		blockoverride "title_icon" {
			icon = {
				using = tooltip_title_icon_size
				texture = "gfx/interface/icons/flat_icons/estates/estates.dds"
				texture_density = 2
				icon = {
					size = {70% 70%}
					parentanchor = center
					texture = "gfx/interface/icons/foreign_country/power.dds"
	
					glow = {
						name = "drop_shadow"
						glow_radius = 2
						color = {0.0 0.0 0.0 1.0}
					}
				}
			}
		}
		blockoverride "title_button" {
            hint_button = {
                action_tooltip = {
                    title = "OPEN_HINT"
                    on_action = "[OpenLateralViewWithParams('hints', 'selected_hint = hint_estates')]"
                }
            }
        }

		blockoverride "title_text" {
			text = "COUNTRY_ESTATE_POWER_TOOLTIP_HEADER"			
		}

		blockoverride "concept_link" {
			text = [estate_power|E]
		}

		blockoverride "tooltip_content" {
			using = CountryEstatesPowerTooltipChart

			# ── VI TRM: Land Ownership Section ──────────────────────────────────────
			# Visible only for the human player (variables only set for is_ai = no).
			# Shows estate name | land size (mln. acres) | gold contribution to DILT
			# Crown: shows SCL (its rent income going to treasury)
			# Others: shows BLE_X * land_tax (their land tax going to treasury)
			# Sum of gold column = DILT
			TooltipContentSection = {
				visible = "[IsPlayerValid]"

				vbox = {
					layoutpolicy_horizontal = expanding
					spacing = 3

					# Single header row: "Land Ownership" | "Land size owned" | "Rent/Land tax"
					hbox = {
						layoutpolicy_horizontal = expanding
						margin = { 4 2 }
						spacing = 4

						text_single = {
							layoutpolicy_horizontal = expanding
							align = left|nobaseline
							fontsize = 14
							text = "VI_LAND_OWNERSHIP_HEADER"
							default_format = "#Y"
						}
						text_single = {
							layoutpolicy_horizontal = expanding
							minimumsize = { 140 -1 }
							align = center|nobaseline
							fontsize = 14
							text = "VI_LAND_OWNERSHIP_LAND_SIZE_COL"
							default_format = "#high"
						}
						text_single = {
							minimumsize = { 80 -1 }
							align = right|nobaseline
							fontsize = 14
							text = "VI_LAND_OWNERSHIP_GOLD_COL"
							default_format = "#high"
						}
					}

					# Per-estate rows — vbox of hboxes matching header column widths exactly
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 2

						datamodel = "[InGameTopbar.GetEstates]"
						item = {
							hbox = {
								layoutpolicy_horizontal = expanding
								margin = { 4 0 }
								spacing = 4

								# Col 1: Estate name — expanding
								text_single = {
									layoutpolicy_horizontal = expanding
									align = left|nobaseline
									fontsize = 14
									text = "[EstatesItem.GetEstate.GetName]"
								}

								# Col 2: Land size — fixed width, centered
								# Shows vi_lo_X × 0.25 (mln. acres) per estate.
								# Crown identified by index 0 (name varies by government type).
								# All other estates identified by GetNameWithNoTooltip.
								# Each text_single has a tooltipwidget showing the current-tier
								# land-share effects (positive + negative) for that estate.
								widget = {
									layoutpolicy_horizontal = expanding
									minimumsize = { 140 -1 }

									# ── Crown ──
									text_single = {
										parentanchor = hcenter|vcenter
										align = center|nobaseline
										fontsize = 14
										visible = "[EqualTo_int32(PdxGuiWidget.GetIndexInDataModel, '(int32)0')]"
										raw_text = "[Multiply_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_lo_crown').GetValue, '(CFixedPoint)0.25')|2] mln. acres"
										tooltipwidget = {
											ContextualTooltipType = {
												blockoverride "title_text" {
													text = "vi_share_tt_header"
												}
												blockoverride "tooltip_content" {
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.10'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.25'))]"
														blockoverride "text" {
															text = "vi_share_crown_t2"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.25'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.50'))]"
														blockoverride "text" {
															text = "vi_share_crown_t3"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.50'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.70'))]"
														blockoverride "text" {
															text = "vi_share_crown_t4"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.70'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.90'))]"
														blockoverride "text" {
															text = "vi_share_crown_t5"
														}
													}
													TooltipTextBlock = {
														visible = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_crown').GetValue, '(CFixedPoint)0.90')]"
														blockoverride "text" {
															text = "vi_share_crown_t6"
														}
													}
												}
											}
										}
									}

									# ── Nobles ──
									text_single = {
										parentanchor = hcenter|vcenter
										align = center|nobaseline
										fontsize = 14
										visible = "[EqualTo_string(EstatesItem.GetEstate.GetType.GetNameWithNoTooltip, Localize('nobles_estate'))]"
										raw_text = "[Multiply_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_lo_nobles').GetValue, '(CFixedPoint)0.25')|2] mln. acres"
										tooltipwidget = {
											ContextualTooltipType = {
												blockoverride "title_text" {
													text = "vi_share_tt_header"
												}
												blockoverride "tooltip_content" {
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.10'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.25'))]"
														blockoverride "text" {
															text = "vi_share_nobles_t2"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.25'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.50'))]"
														blockoverride "text" {
															text = "vi_share_nobles_t3"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.50'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.70'))]"
														blockoverride "text" {
															text = "vi_share_nobles_t4"
														}
													}
													TooltipTextBlock = {
														visible = "[And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.70'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.90'))]"
														blockoverride "text" {
															text = "vi_share_nobles_t5"
														}
													}
													TooltipTextBlock = {
														visible = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_nobles').GetValue, '(CFixedPoint)0.90')]"
														blockoverride "text" {
															text = "vi_share_nobles_t6"
														}
													}
												}
											}
										}
									}

									# ── Clergy ──
									text_single = {
										parentanchor = hcenter|vcenter
										align = center|nobaseline
										fontsize = 14
										visible = "[EqualTo_string(EstatesItem.GetEstate.GetType.GetNameWithNoTooltip, Localize('clergy_estate'))]"
										raw_text = "[Multiply_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_lo_clergy').GetValue, '(CFixedPoint)0.25')|2] mln. acres"
										tooltipwidget = {
											ContextualTooltipType = {
												blockoverride "title_text" {
													text = "vi_share_tt_header"
												}
												blockoverride "tooltip_content" {
													TooltipTextBlock = {
														visible = "[And(And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.10'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.25')), GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_is_christian').GetValue, '(CFixedPoint)0.5'))]"
														blockoverride "text" {
															text = "vi_share_clergy_chr_t2"
														}
													}
													TooltipTextBlock = {
														visible = "[And(And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.10'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.25')), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_is_christian').GetValue, '(CFixedPoint)0.5'))]"
														blockoverride "text" {
															text = "vi_share_clergy_oth_t2"
														}
													}
													TooltipTextBlock = {
														visible = "[And(And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.25'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.50')), GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_is_christian').GetValue, '(CFixedPoint)0.5'))]"
														blockoverride "text" {
															text = "vi_share_clergy_chr_t3"
														}
													}
													TooltipTextBlock = {
														visible = "[And(And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.25'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.50')), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_is_christian').GetValue, '(CFixedPoint)0.5'))]"
														blockoverride "text" {
