														blockoverride "text" {
															text = "vi_share_clergy_chr_t4"
														}
													}
													TooltipTextBlock = {
														visible = "[And(And(GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.50'), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_clergy').GetValue, '(CFixedPoint)0.70')), LessThan_CFixedPoint(GetPlayer.MakeScope.GetVariable('vi_share_is_christian').GetValue, '(CFixedPoint)0.5'))]"
														blockoverride "text" {
