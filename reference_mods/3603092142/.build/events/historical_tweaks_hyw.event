historical_tweaks_hyw.7 = {
    type = country_event

    hidden = yes
    fire_only_once = no

    dynamic_historical_event = {
        tag = FRA
        from = 1330.1.1
        to = 1370.1.1
        monthly_chance = 10
    }

    trigger = {
        tag = FRA
        is_situation_active = situation:hundred_years_war
    }

    option = {
        every_subject_or_below = {
            limit = {
                num_locations < 7
                is_ai = yes
            }
            add_country_modifier = {
                modifier = ht_fra_small_appange
                years = 2
                mode = replace
            }
            every_owned_location = {
                change_control = control_radical_penalty
            }
        }
    }
}

