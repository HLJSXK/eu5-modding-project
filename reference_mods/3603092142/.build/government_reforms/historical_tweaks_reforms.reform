
ht_custom_name_prefix = {
	name = "Country Prefix"
	desc = "Our state styles itself with an unusual rank."

	potential = { has_reform = government_reform:ht_custom_name_prefix }
	allow = { always = yes }
	locked = { is_ai = yes }

	country_modifier = {
		government_reform_slots = 1
	}
}

