"country_name_construction.txt" = {
	pull = "in_game/common/customizable_localization"

	path = "country_name_construction"
	key_path = "localization_key"
	header = 1 #append after type = country
	reverse = yes
	
	country_name_construction = {

		text = {
			localization_key = country_name_construction_name
			trigger = {
				has_reform = government_reform:ht_custom_name_noprefix
			}
		}

	}
}